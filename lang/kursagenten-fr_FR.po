msgid " - side %d av %d"
msgstr " - page %d sur %d"

msgid "-- Velg side --"
msgstr "-- Sélectionner une page --"

msgid "– Brukes for feilsøking og oversikt"
msgstr "– Utilisé pour le dépannage et la vue d'ensemble"

msgid "– side %1$d av %2$d"
msgstr "– page %1$d sur %2$d"

msgid "\"Slug\" er den SEO-vennlige versjonen av url-en. Eksempel /kari-norman"
msgstr "« Slug » est la version optimisée SEO de l'URL. Exemple /kari-norman"

msgid "\"Slug\" er den SEO-vennlige versjonen av url-en. Eksempel /mitt-kurs"
msgstr "« Slug » est la version optimisée SEO de l'URL. Exemple /my-course"

msgid "\"Slug\" er den SEO-vennlige versjonen av url-en. Eksempel /oslo"
msgstr "« Slug » est la version optimisée SEO de l'URL. Exemple /oslo"

msgid "(100-1000px)"
msgstr "(100-1000px)"

msgid "* Merk: Denne delen er fortsatt under utvikling."
msgstr "* Remarque : cette section est encore en cours de développement."

msgid "%1$d %2$s valgt"
msgstr "%1$d %2$s sélectionné(s)"

msgid "%1$s har samme slug som %2$s \"%3$s\""
msgstr "%1$s a le même slug que %2$s « %3$s »"

msgid "%d %s valgt"
msgstr "%d %s sélectionné(s)"

msgid "← Tilbake til instruktører"
msgstr "← Retour aux instructeurs"

msgid "← Tilbake til kurskategorier"
msgstr "← Retour aux catégories de cours"

msgid "← Tilbake til kurssteder"
msgstr "← Retour aux lieux de cours"

msgid "+%d flere"
msgstr "+%d de plus"

msgid "<a href=\"admin.php?page=design\">Kursdesign</a> – Opprett ønskede sider for kurs, kategorier, steder og instruktører via \"Wordpress sider\". Kortkoder legges inn automatisk."
msgstr "<a href=\"admin.php?page=design\">Conception des cours</a> – Créez les pages dont vous avez besoin pour les cours, les catégories, les lieux et les instructeurs via « Pages WordPress ». Les shortcodes sont insérés automatiquement."

msgid "<em>Skjul kategorien og alle tilhørende kurs</em> – både kategorien og alle kurs som er tagget med kategorien skjules helt fra kurslisten. Nyttig for interne kategorier som ikke skal være synlige for besøkende."
msgstr "<em>Masquer la catégorie et tous les cours associés</em> – la catégorie et tous les cours étiquetés avec la catégorie sont complètement masqués de la liste des cours. Utile pour les catégories internes qui ne doivent pas être visibles pour les visiteurs."

msgid "<em>Skjul kun kategorien fra filter</em> – kategorien skjules fra filtervalgene, men kurs som er tagget med kategorien vises fortsatt i kurslisten under sine andre kategorier. Nyttig for «brede» tagger som ikke gir mening som filter (f.eks. «Foredrag», «HMS og sikkerhetskurs»)."
msgstr "<em>Masquer uniquement la catégorie du filtre</em> – la catégorie est masquée dans les options de filtre, mais les cours étiquetés avec la catégorie apparaissent toujours dans la liste des cours sous leurs autres catégories. Utile pour les balises « larges » qui n'ont pas de sens en tant que filtres (par ex. « Conférences », « HMS et cours de sécurité »)."

msgid "<em>Vis</em> – kategorien vises i filteret og kursene vises i listen (standard)."
msgstr "<em>Afficher</em> – la catégorie apparaît dans le filtre et les cours apparaissent dans la liste (par défaut)."

msgid "<p><strong>Bruk Kursagenten instruktørprofil i stedet:</strong></p><ol><li>Slett denne instruktøren</li><li>Lagre et kurs i Kursagenten hvor instruktøren er lagt inn</li></ol>"
msgstr "<p><strong>Utiliser plutôt le profil instructeur Kursagenten :</strong></p><ol><li>Supprimer cet instructeur</li><li>Enregistrer un cours dans Kursagenten où l'instructeur est ajouté</li></ol>"

msgid "<p><strong>Gå tilbake til Kursagenten-data:</strong></p><ol><li>Deaktiver \"Overstyr profil fra Kursagenten\" knappen</li><li>Oppdater instruktørprofilen i Kursagenten</li><li>Profilen oppdateres her. Merk: instruktøren må være knyttet til et kurs for at dataene skal bli hentet over.</li></ol><p>- Bruker du data fra Kursagenten, slipper du å holde dem oppdatert to steder.<br>- En instruktør som er opprettet i Kursagenten med det samme navnet, vil automatisk bli slått sammen med denne instruktøren.</p>"
msgstr "<p><strong>Revenir aux données Kursagenten :</strong></p><ol><li>Désactiver le bouton « Remplacer le profil depuis Kursagenten »</li><li>Mettre à jour le profil de l'instructeur dans Kursagenten</li><li>Le profil est mis à jour ici. Remarque : l'instructeur doit être lié à un cours pour que les données soient récupérées.</li></ol><p>- Si vous utilisez les données de Kursagenten, vous n'avez pas besoin de les maintenir à jour à deux endroits.<br>- Un instructeur créé dans Kursagenten avec le même nom sera automatiquement fusionné avec cet instructeur.</p>"

msgid "<strong>Advarsel:</strong> Navn og slug på kurssteder kan ikke endres her. Du kan endre navnet under <a href=\"%s\">Synkronisering</a>."
msgstr "<strong>Avertissement :</strong> le nom et le slug des lieux de cours ne peuvent pas être modifiés ici. Vous pouvez modifier le nom sous <a href=\"%s\">Synchronisation</a>."

msgid "<strong>Alternativt bilde:</strong> Et ekstra bilde som kan brukes på instruktørsiden."
msgstr "<strong>Image alternative :</strong> une image supplémentaire qui peut être utilisée sur la page de l'instructeur."

msgid "<strong>Antall per side:</strong> Velg antall kurs som skal vises per side."
msgstr "<strong>Nombre par page :</strong> choisissez combien de cours afficher par page."

msgid "<strong>Automatisk opprettelse:</strong> Gå til <a href=\"admin.php?page=design#section-systemsider\">Kursdesign → Wordpress sider</a> og klikk på \"Opprett side\" for hver side du trenger. Kortkoden legges inn automatisk."
msgstr "<strong>Création automatique :</strong> accédez à <a href=\"admin.php?page=design#section-systemsider\">Conception des cours → Pages WordPress</a> et cliquez sur « Créer une page » pour chaque page dont vous avez besoin. Le shortcode est inséré automatiquement."

msgid "<strong>Automatisk opprydding:</strong> Det kjøres også en automatisk nattlig opprydding klokken 03:00 hver natt, så det er ikke alltid nødvendig å kjøre opprydding manuelt. Bruk manuell opprydding hvis du har mange utløpte kursdatoer som vises på nettsiden og ønsker å rydde opp umiddelbart."
msgstr "<strong>Nettoyage automatique :</strong> un nettoyage nocturne automatique s'exécute également à 03h00 chaque nuit, le nettoyage manuel n'est donc pas toujours nécessaire. Utilisez le nettoyage manuel si de nombreuses dates de cours expirées s'affichent sur le site et que vous souhaitez nettoyer immédiatement."

msgid "<strong>Automatisk synkronisering via webhooks:</strong> Når webhooks er konfigurert, oppdateres kursene automatisk når de endres i Kursagenten. Dette er den anbefalte metoden for løpende oppdateringer."
msgstr "<strong>Synchronisation automatique via webhooks :</strong> lorsque les webhooks sont configurés, les cours sont mis à jour automatiquement lorsqu'ils changent dans Kursagenten. C'est la méthode recommandée pour les mises à jour continues."

msgid "<strong>Automatisk:</strong> Steder blir automatisk tilordnet til regioner basert på fylke når regioner er aktivert."
msgstr "<strong>Automatique :</strong> les lieux sont automatiquement attribués aux régions en fonction du comté lorsque les régions sont activées."

msgid "<strong>Avkrysning før synkronisering:</strong> Når du klikker på \"Hent alle kurs fra Kursagenten\", kan du kryss av for \"Rydd opp i kurs etter synkronisering\". Dette kjører opprydding automatisk etter at synkroniseringen er fullført. <strong>NB:</strong> Opprydding tar 3-5 minutter ekstra."
msgstr "<strong>Case à cocher avant la synchronisation :</strong> lorsque vous cliquez sur « Récupérer tous les cours depuis Kursagenten », vous pouvez cocher « Nettoyer les cours après la synchronisation ». Le nettoyage s'exécute automatiquement une fois la synchronisation terminée. <strong>Remarque :</strong> le nettoyage prend 3 à 5 minutes supplémentaires."

msgid "<strong>Bilde:</strong> Et bilde som vises på stedssiden og i lister."
msgstr "<strong>Image :</strong> une image affichée sur la page du lieu et dans les listes."

msgid "<strong>Bilde:</strong> Last opp et hovedbilde som vises på taksonomisiden og i lister."
msgstr "<strong>Image :</strong> téléversez une image principale affichée sur la page de taxonomie et dans les listes."

msgid "<strong>Bilder:</strong> Bruk plassholder-bilder via kortkodene om du mangler bilder."
msgstr "<strong>Images :</strong> utilisez des images de remplacement via les shortcodes si des images manquent."

msgid "<strong>Bredde:</strong> Velg om du vil bruke temaets standardbredde eller full bredde. Stort sett vil standardbredde fungerer som tiltenkt."
msgstr "<strong>Largeur :</strong> choisissez d'utiliser la largeur par défaut du thème ou la pleine largeur. Dans la plupart des cas, la largeur par défaut fonctionne comme prévu."

msgid "<strong>Bruk i kortkoder:</strong> Du kan filtrere kurssteder basert på region i kortkoden <code class=\"copytext\">[kurssteder]</code>:"
msgstr "<strong>Utilisation dans les shortcodes :</strong> vous pouvez filtrer les lieux de cours par région dans le shortcode <code class=\"copytext\">[kurssteder]</code> :"

msgid "<strong>Bygg ditt eget design</strong> er aktivt. Du kan fortsatt styre kursdata-visning under."
msgstr "<strong>Créez votre propre design</strong> est actif. Vous pouvez toujours contrôler l'affichage des données de cours ci-dessous."

msgid "<strong>Bygg ditt eget design</strong> er aktivt. Kursagenten bruker WordPress sitt malhierarki, slik at tema/page builder kan styre oppsett."
msgstr "<strong>Créez votre propre design</strong> est actif. Kursagenten utilise la hiérarchie de modèles WordPress afin que votre thème/page builder puisse contrôler la mise en page."

msgid "<strong>Byggeblokker kommer:</strong> vi planlegger moduler for blant annet kursliste med kurssteder/lenker og informasjon om kommende kurs."
msgstr "<strong>Blocs à venir :</strong> nous prévoyons des modules pour les listes de cours avec lieux/liens de cours et informations sur les cours à venir."

msgid "<strong>Cache:</strong> Tøm cache hvis du ikke ser endringer umiddelbart."
msgstr "<strong>Cache :</strong> videz le cache si vous ne voyez pas les modifications immédiatement."

msgid "<strong>Designendringer:</strong> Hvis designendringer ikke vises, kan det være nødvendig å tømme cache og oppdatere permalenker."
msgstr "<strong>Modifications de design :</strong> si les modifications de design n'apparaissent pas, vous devrez peut-être vider le cache et mettre à jour les permaliens."

msgid "<strong>E-post:</strong> Instruktørens e-postadresse."
msgstr "<strong>E-mail :</strong> l'adresse e-mail de l'instructeur."

msgid "<strong>Egen opprydding:</strong> Du kan også kjøre opprydding separat ved å klikke på knappen \"Rydd opp i kurs\" på <a href=\"admin.php?page=kursinnstillinger\">Synkronisering</a>-siden. Dette er nyttig hvis du bare ønsker å rydde opp uten å synkronisere alle kursene på nytt."
msgstr "<strong>Nettoyage séparé :</strong> vous pouvez également exécuter le nettoyage séparément en cliquant sur le bouton « Nettoyer les cours » sur la page <a href=\"admin.php?page=kursinnstillinger\">Synchronisation</a>. C'est utile si vous souhaitez uniquement nettoyer sans resynchroniser tous les cours."

msgid "<strong>Eget innhold over/under:</strong> Du kan legge inn vanlig innhold i editoren over og under kortkoden for å skrive en introduksjon, legge til bilder eller annen informasjon."
msgstr "<strong>Contenu personnalisé au-dessus/en dessous :</strong> vous pouvez ajouter du contenu classique dans l'éditeur au-dessus et en dessous du shortcode pour rédiger une introduction, ajouter des images ou d'autres informations."

msgid "<strong>Ekstra felter:</strong> Spesifikke felter avhengig av taksonomitypen (se nedenfor)."
msgstr "<strong>Champs supplémentaires :</strong> champs spécifiques selon le type de taxonomie (voir ci-dessous)."

msgid "<strong>Enkel - kun tittel og kort beskrivelse:</strong> Tittel og kort beskrivelse, deretter kursliste. Egnet når du ikke har bilder eller utvidet beskrivelse."
msgstr "<strong>Simple – titre et description courte uniquement :</strong> titre et description courte, puis liste de cours. Adapté lorsque vous n'avez pas d'images ni de description étendue."

msgid "<strong>Enkle kort:</strong> Hvite kort med overskrift og tekst. Viser neste tilgjengelige dato for kursene. Mulig å velge antall kolonner for desktop, tablet og mobil."
msgstr "<strong>Cartes simples :</strong> cartes blanches avec titre et texte. Affiche la prochaine date disponible pour les cours. Vous pouvez choisir le nombre de colonnes pour ordinateur, tablette et mobile."

msgid "<strong>Felles designmal:</strong> Alle taksonomier bruker samme designmal."
msgstr "<strong>Modèle de design partagé :</strong> toutes les taxonomies utilisent le même modèle de design."

msgid "<strong>Grid:</strong> Et rutenett med kurskort i flere kolonner. Mulig å velge antall kolonner for desktop, tablet og mobil."
msgstr "<strong>Grille :</strong> une grille de cartes de cours sur plusieurs colonnes. Vous pouvez choisir le nombre de colonnes pour ordinateur, tablette et mobile."

msgid "<strong>Hovedbilde:</strong> Et bilde som vises på kategorisiden og i lister."
msgstr "<strong>Image principale :</strong> une image affichée sur la page de catégorie et dans les listes."

msgid "<strong>Hva er kortkoder?</strong> Kortkoder er små koder du plasserer i innhold (sider/innlegg) for å vise dynamiske lister og komponenter fra pluginen."
msgstr "<strong>Que sont les shortcodes ?</strong> Les shortcodes sont de petits codes que vous placez dans le contenu (pages/articles) pour afficher des listes dynamiques et des composants de l'extension."

msgid "<strong>Hvor brukes de?</strong> Vanligvis på egne sider eller innlegg (f.eks. «Kurs», «Kurskategorier», «Kurssteder», «Instruktører»). Du kan også bruke dem i menyen eller widgets."
msgstr "<strong>Où sont-ils utilisés ?</strong> Généralement sur des pages ou articles dédiés (par ex. « Cours », « Catégories de cours », « Lieux de cours », « Instructeurs »). Vous pouvez également les utiliser dans les menus ou les widgets."

msgid "<strong>Ikon:</strong> Et alternativt bilde som kan brukes i stedet for hovedbilde i lister. Her er det fint å laste opp png-ikoner (bruk <code>kilde=ikon</code> i kortkoden)."
msgstr "<strong>Icône :</strong> une image alternative qui peut être utilisée à la place de l'image principale dans les listes. Les icônes PNG conviennent bien ici (utilisez <code>kilde=ikon</code> dans le shortcode)."

msgid "<strong>Instruktører</strong> – Inneholder <code class=\"copytext\">[instruktorer]</code> for å vise alle instruktører."
msgstr "<strong>Instructeurs</strong> – Contient <code class=\"copytext\">[instruktorer]</code> pour afficher tous les instructeurs."

msgid "<strong>Kompakt:</strong> En mer kompakt listevisning med mindre mellomrom. Uten bakgrunn, og med færre kurselementer"
msgstr "<strong>Compact :</strong> une vue de liste plus compacte avec moins d'espacement. Sans arrière-plan et avec moins d'éléments de cours."

msgid "<strong>Kort beskrivelse:</strong> En kort tekst som kan vises i lister og oversikter. Vises ofte direkte under overskriften."
msgstr "<strong>Description courte :</strong> un texte court qui peut être affiché dans les listes et les vues d'ensemble. Souvent affiché directement sous le titre."

msgid "<strong>Kort beskrivelse:</strong> En kort tekst som kan vises i lister."
msgstr "<strong>Description courte :</strong> un texte court qui peut être affiché dans les listes."

msgid "<strong>Kort beskrivelse:</strong> En kort tekst som kan vises i lister. Vises ofte direkte under overskriften."
msgstr "<strong>Description courte :</strong> un texte court qui peut être affiché dans les listes. Souvent affiché directement sous le titre."

msgid "<strong>Kurs</strong> – Inneholder <code class=\"copytext\">[kursliste]</code> for å vise alle kurs med filtre."
msgstr "<strong>Cours</strong> – Contient <code class=\"copytext\">[kursliste]</code> pour afficher tous les cours avec filtres."

msgid "<strong>Kurskategorier</strong> – Inneholder <code class=\"copytext\">[kurskategorier]</code> for å vise alle kategorier."
msgstr "<strong>Catégories de cours</strong> – Contient <code class=\"copytext\">[kurskategorier]</code> pour afficher toutes les catégories."

msgid "<strong>Kursliste (kun for kurskategorier):</strong> Tre alternativer styrer hvordan kategorien påvirker kurslisten:"
msgstr "<strong>Liste de cours (catégories de cours uniquement) :</strong> trois options contrôlent la façon dont la catégorie affecte la liste de cours :"

msgid "<strong>Kursliste med filter </strong><span class=\"smal\"><span class=\"copytext\">[kursliste]</span></span><br><span class=\"copytext small\">[kursliste kategori=\"web\" sted=\"oslo\" måned=\"9\" språk=\"norsk\" list_type=\"grid\" filter=\"topp\" knapper=\"signup_link\" bilder=\"yes\" vis=\"-sluttdato\" st=sted/st=ikke-sted klasse=\"min-klasse\"]</span>"
msgstr "<strong>Liste de cours avec filtre </strong><span class=\"smal\"><span class=\"copytext\">[kursliste]</span></span><br><span class=\"copytext small\">[kursliste kategori=\"web\" sted=\"oslo\" måned=\"9\" språk=\"norsk\" list_type=\"grid\" filter=\"topp\" knapper=\"signup_link\" bilder=\"yes\" vis=\"-sluttdato\" st=sted/st=ikke-sted klasse=\"min-klasse\"]</span>"

msgid "<strong>Kurssteder opprettes automatisk</strong> når du synkroniserer kurs fra Kursagenten. Du kan ikke legge til kurssteder manuelt her."
msgstr "<strong>Les lieux de cours sont créés automatiquement</strong> lorsque vous synchronisez les cours depuis Kursagenten. Vous ne pouvez pas ajouter de lieux de cours manuellement ici."

msgid "<strong>Kurssteder</strong> – Inneholder <code class=\"copytext\">[kurssteder]</code> for å vise alle kurssteder."
msgstr "<strong>Lieux de cours</strong> – Contient <code class=\"copytext\">[kurssteder]</code> pour afficher tous les lieux de cours."

msgid "<strong>Layout og struktur:</strong> Hvor elementene plasseres på siden (header, innhold, sidekolonne, footer)."
msgstr "<strong>Mise en page et structure :</strong> l'emplacement des éléments sur la page (en-tête, contenu, barre latérale, pied de page)."

msgid "<strong>Layout:</strong> Velg designet på siden. Dette styrer hvor/hvordan tittel, tekst, hovedbilde og kursliste vises."
msgstr "<strong>Mise en page :</strong> choisissez le design de la page. Cela contrôle où/comment le titre, le texte, l'image principale et la liste de cours sont affichés."

msgid "<strong>Layout</strong> bestemmer oppsettet av elementer på siden (header, kolonner, hooks).</br><strong>Listedesign</strong> bestemmer hvordan kursene vises i listen (standard, rutenett, ren, kompakt, dato og tittel). </br><strong>Visningstype</strong> bestemmer om du vil vise hovedkurs eller alle kursdatoer."
msgstr "<strong>La mise en page</strong> détermine la disposition des éléments sur la page (en-tête, colonnes, hooks).</br><strong>Le design de liste</strong> détermine comment les cours sont affichés dans la liste (par défaut, grille, épuré, compact, date et titre). </br><strong>Le type d'affichage</strong> détermine s'il faut afficher les cours principaux ou toutes les dates de cours."

msgid "<strong>Liste med instruktører </strong><span class=\"smal\"><span class=\"copytext\">[instruktorer]</span></span><br><span class=\"copytext small\" style=\"color:#666\">[instruktorer layout=\"stablet/rad/liste\" grid=3 gridtablet=2 gridmobil=1 radavstand=\"1rem\" stil=\"standard/kort\" bildestr=\"100px\" bildeform=\"avrundet/rund/firkantet/10px\" bildeformat=\"4/3\" overskrift=\"h3\" fontmin=\"13px\" fontmaks=\"15px\" avstand=\"2em .5em\" skygge=\"ja\" skjul=\"Iris,Anna\" utdrag=\"ja\" beskrivelse=\"ja\" klasse=\"min-klasse\"]</span>"
msgstr "<strong>Liste des instructeurs </strong><span class=\"smal\"><span class=\"copytext\">[instruktorer]</span></span><br><span class=\"copytext small\" style=\"color:#666\">[instruktorer layout=\"stablet/rad/liste\" grid=3 gridtablet=2 gridmobil=1 radavstand=\"1rem\" stil=\"standard/kort\" bildestr=\"100px\" bildeform=\"avrundet/rund/firkantet/10px\" bildeformat=\"4/3\" overskrift=\"h3\" fontmin=\"13px\" fontmaks=\"15px\" avstand=\"2em .5em\" skygge=\"ja\" skjul=\"Iris,Anna\" utdrag=\"ja\" beskrivelse=\"ja\" klasse=\"min-klasse\"]</span>"

msgid "<strong>Liste med kurskategorier </strong><span class=\"smal\"><span class=\"copytext\">[kurskategorier]</span></span><br><span class=\"copytext small\" style=\"color:#666\">[kurskategorier kilde=\"bilde/ikon\" layout=\"stablet/rad/liste\" grid=3 gridtablet=2 gridmobil=1  radavstand=\"1rem\" stil=\"standard/kort\" bildestr=\"100px\" bildeform=\"avrundet/rund/firkantet/10px\" bildeformat=\"4/3\" overskrift=\"h3\" fontmin=\"13\" fontmaks=\"18\" avstand=\"2em .5em\" skygge=\"ja\" vis=\"hovedkategorier/subkategorier/slug/standard\" st=sted/st=ikke-sted utdrag=\"ja\" klasse=\"min-klasse\"]</span>"
msgstr "<strong>Liste des catégories de cours </strong><span class=\"smal\"><span class=\"copytext\">[kurskategorier]</span></span><br><span class=\"copytext small\" style=\"color:#666\">[kurskategorier kilde=\"bilde/ikon\" layout=\"stablet/rad/liste\" grid=3 gridtablet=2 gridmobil=1  radavstand=\"1rem\" stil=\"standard/kort\" bildestr=\"100px\" bildeform=\"avrundet/rund/firkantet/10px\" bildeformat=\"4/3\" overskrift=\"h3\" fontmin=\"13\" fontmaks=\"18\" avstand=\"2em .5em\" skygge=\"ja\" vis=\"hovedkategorier/subkategorier/slug/standard\" st=sted/st=ikke-sted utdrag=\"ja\" klasse=\"min-klasse\"]</span>"

msgid "<strong>Liste med kurssteder </strong><span class=\"smal\"><span class=\"copytext\">[kurssteder]</span></span><br><span class=\"copytext small\" style=\"color:#666\">[kurssteder layout=\"stablet/rad/liste\" grid=3 gridtablet=2 gridmobil=1 radavstand=\"1rem\" stil=\"standard/kort\" bildestr=\"100px\" bildeform=\"avrundet/rund/firkantet/10px\" bildeformat=\"4/3\" overskrift=\"h3\" fontmin=\"13px\" fontmaks=\"15px\" avstand=\"2em .5em\" skygge=\"ja\" utdrag=\"ja\" vis=\"standard/alta,oslo,bergen\" region=\"østlandet\" stedinfo=\"ja\" klasse=\"min-klasse\"]</span>"
msgstr "<strong>Liste des lieux de cours </strong><span class=\"smal\"><span class=\"copytext\">[kurssteder]</span></span><br><span class=\"copytext small\" style=\"color:#666\">[kurssteder layout=\"stablet/rad/liste\" grid=3 gridtablet=2 gridmobil=1 radavstand=\"1rem\" stil=\"standard/kort\" bildestr=\"100px\" bildeform=\"avrundet/rund/firkantet/10px\" bildeformat=\"4/3\" overskrift=\"h3\" fontmin=\"13px\" fontmaks=\"15px\" avstand=\"2em .5em\" skygge=\"ja\" utdrag=\"ja\" vis=\"standard/alta,oslo,bergen\" region=\"østlandet\" stedinfo=\"ja\" klasse=\"min-klasse\"]</span>"

msgid "<strong>Listedesign:</strong> Velg designet på kurslisten (standard, rutenett, kompakt, enkle kort...)"
msgstr "<strong>Design de liste :</strong> choisissez le design de la liste de cours (par défaut, grille, compact, cartes simples...)"

msgid "<strong>Listedesign:</strong> Velg listedesign (standard, rutenett, kompakt, enkel liste, enkle kort)."
msgstr "<strong>Design de liste :</strong> choisissez le design de liste (par défaut, grille, compact, liste simple, cartes simples)."

msgid "<strong>Listedesign</strong> bestemmer hvordan kursene vises i listen (standard, rutenett, ren, kompakt, dato og tittel)."
msgstr "<strong>Le design de liste</strong> détermine comment les cours sont affichés dans la liste (par défaut, grille, épuré, compact, date et titre)."

msgid "<strong>Manuell synkronisering:</strong> Gå til <a href=\"admin.php?page=kursinnstillinger\">Synkronisering</a> og klikk på \"Hent alle kurs fra Kursagenten\". Dette bør gjøres første gang du setter opp pluginen, og ved behov for å oppdatere alle kursene samtidig."
msgstr "<strong>Synchronisation manuelle :</strong> accédez à <a href=\"admin.php?page=kursinnstillinger\">Synchronisation</a> et cliquez sur « Récupérer tous les cours depuis Kursagenten ». Cela doit être fait la première fois que vous configurez l'extension, et lorsque vous devez mettre à jour tous les cours en une fois."

msgid "<strong>Manuelt:</strong> Du kan endre region for individuelle steder ved å redigere kursstedet i <a href=\"edit-tags.php?taxonomy=ka_course_location&post_type=ka_course\">Kurssteder</a>-oversikten."
msgstr "<strong>Manuel :</strong> vous pouvez modifier la région pour des lieux individuels en modifiant le lieu de cours dans la vue d'ensemble des <a href=\"edit-tags.php?taxonomy=ka_course_location&post_type=ka_course\">Lieux de cours</a>."

msgid "<strong>Merk:</strong> Regioner må være aktivert for at filtreringen skal fungere. Du kan også endre region for individuelle kurssteder ved å redigere kursstedet i <a href=\"edit-tags.php?taxonomy=ka_course_location&post_type=ka_course\">Kurssteder</a>-oversikten."
msgstr "<strong>Remarque :</strong> les régions doivent être activées pour que le filtrage fonctionne. Vous pouvez également modifier la région pour des lieux de cours individuels en modifiant le lieu dans la vue d'ensemble des <a href=\"edit-tags.php?taxonomy=ka_course_location&post_type=ka_course\">Lieux de cours</a>."

msgid "<strong>Navn:</strong> Instruktørens navn (kan deles opp i fornavn og etternavn)."
msgstr "<strong>Nom :</strong> le nom de l'instructeur (peut être divisé en prénom et nom de famille)."

msgid "<strong>Navn:</strong> Kategorinavnet (kommer fra Kursagenten, bør ikke endres)."
msgstr "<strong>Nom :</strong> le nom de la catégorie (provient de Kursagenten, ne doit pas être modifié)."

msgid "<strong>Navn:</strong> Stedsnavnet (kommer fra Kursagenten, men kan endres via navnendring-funksjonen)."
msgstr "<strong>Nom :</strong> le nom du lieu (provient de Kursagenten, mais peut être modifié via la fonction de changement de nom)."

msgid "<strong>Navnendring på kurssteder:</strong><br>Du kan endre navn på kurssteder under <a href=\"%s\">Synkronisering → Navnendring på kurssteder</a>. Når du endrer navn på et sted, blir også slugs (nettadressen) på kursene som har dette stedet oppdatert.<br> Det gamle stedet blir ikke slettet, men blir ikke lenger synlig på nettsiden."
msgstr "<strong>Changement de nom pour les lieux de cours :</strong><br>Vous pouvez modifier les noms des lieux de cours sous <a href=\"%s\">Synchronisation → Changements de nom des lieux de cours</a>. Lorsque vous modifiez un nom de lieu, les slugs (URL) des cours associés à ce lieu sont également mis à jour.<br> L'ancien lieu n'est pas supprimé, mais n'est plus visible sur le site."

msgid "<strong>Når bør du bruke kortkoder?</strong> Hvis du bygger sidene med Elementor eller andre page builders, vil kortkoder sannsynligvis være det du må bruke."
msgstr "<strong>Quand utiliser les shortcodes ?</strong> Si vous créez des pages avec Elementor ou d'autres page builders, les shortcodes seront probablement ce dont vous avez besoin."

msgid "<strong>Obs:</strong> For at brukerne skal kunne slå filteret av og på, må du dra <em>«Ledige kurs»</em> inn i «Filtre i venstre kolonne» eller «Filtre over kurslisten» under Filterinnstillinger."
msgstr "<strong>Remarque :</strong> pour que les utilisateurs puissent activer et désactiver le filtre, vous devez faire glisser <em>« Cours disponibles »</em> vers « Filtres dans la colonne de gauche » ou « Filtres au-dessus de la liste de cours » sous Paramètres des filtres."

msgid "<strong>OBS!</strong> Fyll inn <a href=\"#kursagenten-innstillinger\" style=\"color:white; text-decoration: underline;\">innstillinger fra Kursagenten</a> før du henter alle kursene dine (synkroniser alle kurs)."
msgstr "<strong>ATTENTION !</strong> Saisissez les <a href=\"#kursagenten-innstillinger\" style=\"color:white; text-decoration: underline;\">paramètres de Kursagenten</a> avant de récupérer tous vos cours (synchroniser tous les cours)."

msgid "<strong>Overstyr profil fra Kursagenten:</strong> Aktiver denne for å kunne redigere navn, e-post og telefon. Når aktivert, vil ikke disse feltene oppdateres automatisk fra Kursagenten ved synkronisering."
msgstr "<strong>Remplacer le profil depuis Kursagenten :</strong> activez cette option pour modifier le nom, l'e-mail et le téléphone. Lorsqu'elle est activée, ces champs ne seront plus mis à jour automatiquement depuis Kursagenten lors de la synchronisation."

msgid "<strong>Overstyr profilbilde:</strong> Aktiver denne for å bruke et eget opplastet bilde i stedet for bildet fra Kursagenten."
msgstr "<strong>Remplacer l'image de profil :</strong> activez cette option pour utiliser votre propre image téléversée au lieu de l'image de Kursagenten."

msgid "<strong>Page builder (Kadence Elements, Elementor m.fl.):</strong> Hvis du vil styre single/archive/taksonomi med page builder-betingelser, gå til <a href=\"admin.php?page=design#section-enkeltkurs\">Kursdesign → Enkeltkurs</a> og aktiver <em>Bruk WordPress sitt standard malhierarki</em>. Da lar pluginen tema/page builder velge mal uten å tvinge pluginens egne layout-filer."
msgstr "<strong>Page builder (Kadence Elements, Elementor, etc.) :</strong> si vous souhaitez contrôler single/archive/taxonomy avec des conditions de page builder, accédez à <a href=\"admin.php?page=design#section-enkeltkurs\">Conception des cours → Cours individuel</a> et activez <em>Utiliser la hiérarchie de modèles WordPress par défaut</em>. L'extension laisse alors le thème/page builder choisir le modèle sans imposer les fichiers de mise en page de l'extension."

msgid "<strong>Permalenker:</strong> Ved endring av URL-innstillinger, lagre «Permalenker» på nytt."
msgstr "<strong>Permaliens :</strong> lors de la modification des paramètres d'URL, enregistrez à nouveau « Permaliens »."

msgid "<strong>Plassering:</strong> Filtrene velges ved å dra dem til korrekt plassering. Du kan velge å vise dem til venstre for kurslisten og/eller over kurslisten."
msgstr "<strong>Placement :</strong> choisissez les filtres en les faisant glisser vers la position correcte. Vous pouvez les afficher à gauche de la liste de cours et/ou au-dessus de la liste de cours."

msgid "<strong>Profil - rundt bilde og tittel:</strong> Rundt bilde, deretter tittel og beskrivelse, deretter kursliste"
msgstr "<strong>Profil – autour de l'image et du titre :</strong> autour de l'image, puis titre et description, puis liste de cours."

msgid "<strong>Profilbilde:</strong> Et hovedbilde som vises på instruktørsiden og i lister. Dette kan være fra Kursagenten eller et eget opplastet bilde."
msgstr "<strong>Image de profil :</strong> une image principale affichée sur la page de l'instructeur et dans les listes. Elle peut provenir de Kursagenten ou de votre propre image téléversée."

msgid "<strong>Region:</strong> (Hvis regioner er aktivert) Velg hvilken region stedet tilhører."
msgstr "<strong>Région :</strong> (si les régions sont activées) choisissez à quelle région appartient le lieu."

msgid "<strong>Regioner:</strong><br>Du kan aktivere og administrere regioner under <a href=\"%s\">Synkronisering → Regioner</a>."
msgstr "<strong>Régions :</strong><br>Vous pouvez activer et gérer les régions sous <a href=\"%s\">Synchronisation → Régions</a>."

msgid "<strong>Regioner:</strong><br>Regioner er aktivert. Du kan administrere regioninndelingen under <a href=\"%s\">Synkronisering → Regioner</a>. Tilhørighet til en region kan endres under hvert kurssted."
msgstr "<strong>Régions :</strong><br>Les régions sont activées. Vous pouvez gérer la division régionale sous <a href=\"%s\">Synchronisation → Régions</a>. L'attribution régionale peut être modifiée pour chaque lieu de cours."

msgid "<strong>Rekkefølge på elementer:</strong> Hvilken rekkefølge informasjonen vises i (introtekst, hovedinnhold, kursdatoer, instruktører, osv.)."
msgstr "<strong>Ordre des éléments :</strong> l'ordre dans lequel les informations sont affichées (texte d'introduction, contenu principal, dates de cours, instructeurs, etc.)."

msgid "<strong>Rekkefølge:</strong> Du kan også dra i filtrene for å endre rekkefølgen de vises i."
msgstr "<strong>Ordre :</strong> vous pouvez également faire glisser les filtres pour modifier l'ordre d'affichage."

msgid "<strong>Ren og enkel liste:</strong> Basert på Standard liste, men uten bakgrunn, og med færre kurselementer"
msgstr "<strong>Liste épurée et simple :</strong> basée sur la liste standard, mais sans arrière-plan et avec moins d'éléments de cours."

msgid "<strong>Separate designmaler:</strong> Aktiver dette for å kunne velge forskjellige designmaler for kategorier, steder og instruktører."
msgstr "<strong>Modèles de design séparés :</strong> activez cette option pour choisir différents modèles de design pour les catégories, les lieux et les instructeurs."

msgid "<strong>Skjul i automenyer:</strong> Når aktivert, skjules kategorien i autogenererte menyer som bruker kortkoden <code>[ka-meny]</code>. Dette er nyttig hvis du har kategorier som ikke skal vises i hovedmenyen."
msgstr "<strong>Masquer dans les menus automatiques :</strong> lorsque cette option est activée, la catégorie est masquée dans les menus générés automatiquement qui utilisent le shortcode <code>[ka-meny]</code>. Utile si vous avez des catégories qui ne doivent pas apparaître dans le menu principal."

msgid "<strong>Skjul i oversiktslister:</strong> Når aktivert, skjules kategorien i kortkoder som <code>[kurskategorier]</code> og lignende lister. Kategorien vil fortsatt være tilgjengelig direkte via URL."
msgstr "<strong>Masquer dans les listes de vue d'ensemble :</strong> lorsque cette option est activée, la catégorie est masquée dans les shortcodes tels que <code>[kurskategorier]</code> et les listes similaires. La catégorie reste accessible directement via l'URL."

msgid "<strong>Slug:</strong> URL-vennlig versjon av navnet (bør ikke endres da det kan føre til ødelagte lenker)."
msgstr "<strong>Slug :</strong> version conviviale pour l'URL du nom (ne doit pas être modifiée car cela peut casser les liens)."

msgid "<strong>Slug:</strong> URL-vennlig versjon av navnet (oppdateres automatisk ved navnendring)."
msgstr "<strong>Slug :</strong> version conviviale pour l'URL du nom (mise à jour automatiquement lors du changement de nom)."

msgid "<strong>Standard - med bilde og beskrivelse:</strong> Tittel og beskrivelse, deretter bilde og beskrivelse, deretter kursliste"
msgstr "<strong>Par défaut – avec image et description :</strong> titre et description, puis image et description, puis liste de cours."

msgid "<strong>Standard:</strong> 1 kolonne"
msgstr "<strong>Par défaut :</strong> 1 colonne"

msgid "<strong>Standard:</strong> 100px"
msgstr "<strong>Par défaut :</strong> 100px"

msgid "<strong>Standard:</strong> 1rem"
msgstr "<strong>Par défaut :</strong> 1rem"

msgid "<strong>Standard:</strong> 2 kolonner"
msgstr "<strong>Par défaut :</strong> 2 colonnes"

msgid "<strong>Standard:</strong> 2em .5em"
msgstr "<strong>Par défaut :</strong> 2em .5em"

msgid "<strong>Standard:</strong> 3 kolonner"
msgstr "<strong>Par défaut :</strong> 3 colonnes"

msgid "<strong>Standard:</strong> En tradisjonell listevisning med kurskort, ett kurs per rad/boks."
msgstr "<strong>Par défaut :</strong> une vue de liste traditionnelle avec des cartes de cours, un cours par ligne/boîte."

msgid "<strong>Synkronisering:</strong> Hvis kurs ikke oppdateres automatisk, sjekk at webhooks er konfigurert korrekt i Kursagenten."
msgstr "<strong>Synchronisation :</strong> si les cours ne sont pas mis à jour automatiquement, vérifiez que les webhooks sont correctement configurés dans Kursagenten."

msgid "<strong>Tagger eller lister:</strong> Filtrene kan velges som tagger eller avkrysningsliste. Tagger er knapper som velger ett filter av gangen, og avkrysningsliste er en liste som kan velge flere filter samtidig."
msgstr "<strong>Balises ou listes :</strong> les filtres peuvent être affichés sous forme de balises ou de cases à cocher. Les balises sont des boutons qui sélectionnent un filtre à la fois ; les cases à cocher permettent de sélectionner plusieurs filtres simultanément."

msgid "<strong>Telefon:</strong> Instruktørens telefonnummer."
msgstr "<strong>Téléphone :</strong> le numéro de téléphone de l'instructeur."

msgid "<strong>Test:</strong> Besøk frontend og se at det ser ut som det skal."
msgstr "<strong>Test :</strong> visitez le front-end et vérifiez que l'affichage est conforme à vos attentes."

msgid "<strong>Utvidet beskrivelse:</strong> En lengre tekst med HTML-formatering som vises på instruktørsiden."
msgstr "<strong>Description étendue :</strong> un texte plus long avec formatage HTML affiché sur la page de l'instructeur."

msgid "<strong>Utvidet beskrivelse:</strong> En lengre tekst med HTML-formatering som vises på kategorisiden."
msgstr "<strong>Description étendue :</strong> un texte plus long avec formatage HTML affiché sur la page de catégorie."

msgid "<strong>Utvidet beskrivelse:</strong> En lengre tekst med HTML-formatering som vises på stedssiden."
msgstr "<strong>Description étendue :</strong> un texte plus long avec formatage HTML affiché sur la page du lieu."

msgid "<strong>Utvidet beskrivelse:</strong> En lengre tekst med rik tekstformatering (HTML) som vises på taksonomisiden. Her kan du beskrive kategorien, stedet eller instruktøren med tekst, bilder og annen informasjon."
msgstr "<strong>Description étendue :</strong> un texte plus long avec formatage de texte enrichi (HTML) affiché sur la page de taxonomie. Vous pouvez y décrire la catégorie, le lieu ou l'instructeur avec du texte, des images et d'autres informations."

msgid "<strong>Velge eksisterende side:</strong> Du kan også velge en eksisterende WordPress-side fra dropdown-menyen og tilordne den til en funksjon. Lim inn kortkoden manuelt. Koden kan du kopiere fra ikonet <i class=\"ka-icon icon-code-simple-solid-full\" style=\"height: 14px;\"></i> ved siden av navnet."
msgstr "<strong>Sélectionner une page existante :</strong> vous pouvez également sélectionner une page WordPress existante dans le menu déroulant et l'attribuer à une fonction. Collez le shortcode manuellement. Vous pouvez copier le code depuis l'icône <i class=\"ka-icon icon-code-simple-solid-full\" style=\"height: 14px;\"></i> à côté du nom."

msgid "<strong>Viktig:</strong> Endringer i designmal kan kreve oppdatering/refresh av cache og permalenker, spesielt ved utstrakte URL-tilpasninger."
msgstr "<strong>Important :</strong> les modifications du modèle de design peuvent nécessiter une actualisation du cache et une mise à jour des permaliens, en particulier pour les personnalisations d'URL étendues."

msgid "<strong>Viktig:</strong> Navnet på kursstedet i WordPress-administrasjonen er skrivebeskyttet når det kommer fra Kursagenten. For å endre navnet som vises på nettsiden, bruk navnendring-funksjonen i stedet for å redigere taksonomien direkte."
msgstr "<strong>Important :</strong> le nom du lieu de cours dans l'administration WordPress est en lecture seule lorsqu'il provient de Kursagenten. Pour modifier le nom affiché sur le site, utilisez la fonction de changement de nom au lieu de modifier directement la taxonomie."

msgid "<strong>Viktig:</strong> Når du overskriver felter, vil de ikke lenger oppdateres automatisk fra Kursagenten. Du må manuelt oppdatere dem hvis det er endringer i Kursagenten."
msgstr "<strong>Important :</strong> lorsque vous remplacez des champs, ils ne seront plus mis à jour automatiquement depuis Kursagenten. Vous devez les mettre à jour manuellement en cas de modifications dans Kursagenten."

msgid "<strong>Vis bilder:</strong> Skru av/på bilder i listen. Best egnet om du har lastet opp bilder til kursene i Kursagenten."
msgstr "<strong>Afficher les images :</strong> activez/désactivez les images dans la liste. Idéal si vous avez téléversé des images pour les cours dans Kursagenten."

msgid "<strong>Vis:</strong> Kategorien vises i filteret, og kurs tagget med kategorien vises i kurslisten.<br><strong>Skjul kun kategorien fra filter:</strong> Kategorien skjules fra filteret, men kurs tagget med denne kategorien vises fortsatt i kurslisten (under sine øvrige kategorier).<br><strong>Skjul kategorien og alle tilhørende kurs:</strong> Verken kategorien eller kurs tagget med denne vises i kurslisten – nyttig for interne kategorier."
msgstr "<strong>Afficher :</strong> la catégorie apparaît dans le filtre et les cours étiquetés avec la catégorie apparaissent dans la liste de cours.<br><strong>Masquer uniquement la catégorie du filtre :</strong> la catégorie est masquée du filtre, mais les cours étiquetés avec cette catégorie apparaissent toujours dans la liste de cours (sous leurs autres catégories).<br><strong>Masquer la catégorie et tous les cours associés :</strong> ni la catégorie ni les cours étiquetés avec celle-ci n'apparaissent dans la liste de cours – utile pour les catégories internes."

msgid "<strong>Visning av liste:</strong> I venstre kolonne vil listene vises som avkrysningsliste, mens over kursliten vises lister som dropdown-menyer."
msgstr "<strong>Affichage de liste :</strong> dans la colonne de gauche, les listes sont affichées sous forme de cases à cocher ; au-dessus de la liste de cours, les listes sont affichées sous forme de menus déroulants."

msgid "<strong>Visningstype:</strong> Velg om du vil vise hovedkurs (ett kurs per rad/boks) eller alle kursdatoer (tilsvarende \"Kursliste med filter\")."
msgstr "<strong>Type d'affichage :</strong> choisissez d'afficher les cours principaux (un cours par ligne/boîte) ou toutes les dates de cours (équivalent à « Liste de cours avec filtre »)."

msgid "<strong>Visningstype</strong> bestemmer om du vil vise hovedkurs eller alle kursdatoer."
msgstr "<strong>Le type d'affichage</strong> détermine s'il faut afficher les cours principaux ou toutes les dates de cours."

msgid "<strong>Visuelle detaljer:</strong> Styling, spacing og annet visuelt design."
msgstr "<strong>Détails visuels :</strong> style, espacement et autres éléments de design visuel."

msgid "✓ (kan overstyres i AIOSEO Pro)"
msgstr "✓ (peut être remplacé dans AIOSEO Pro)"

msgid "✓ (kan overstyres i SEOPress Pro)"
msgstr "✓ (peut être remplacé dans SEOPress Pro)"

msgid "0 = ingen begrensning"
msgstr "0 = aucune limite"

msgid "Adresse"
msgstr "Adresse"

msgid "AJAX-konfigurasjon mangler."
msgstr "La configuration AJAX est manquante."

msgid "Aktiver dette hvis du bruker andre SEO-utvidelser som ikke er listet under, eller ønsker å håndtere SEO helt selv."
msgstr "Activez ceci si vous utilisez d'autres plugins SEO qui ne sont pas listés ci-dessous, ou si vous souhaitez gérer le SEO entièrement par vous-même."

msgid "Aktiver ekstra sikkerhetsfunksjoner"
msgstr "Activer les fonctionnalités de sécurité supplémentaires"

msgid "Aktiver regioninndeling (Sørlandet, Østlandet, Vestlandet, Midt-Norge, Nord-Norge)"
msgstr "Activer la division régionale (Sørlandet, Østlandet, Vestlandet, Midt-Norge, Nord-Norge)"

msgid "Aktiver støtte for jQuery"
msgstr "Activer la prise en charge de jQuery"

msgid "Alle"
msgstr "Tous"

msgid "Alle (%d)"
msgstr "Tous (%d)"

msgid "Alle instruktører"
msgstr "Tous les instructeurs"

msgid "Alle kurs"
msgstr "Tous les cours"

msgid "Alle kurskategorier"
msgstr "Toutes les catégories de cours"

msgid "Alle kurssteder"
msgstr "Tous les lieux de cours"

msgid "Alle steder"
msgstr "Tous les lieux"

msgid "Alle systemsider følger WordPress sin standard template-hierarki, så hvis temaet ditt har egne templates (f.eks. <code>single-ka_course.php</code> eller <code>taxonomy-ka_coursecategory.php</code>), vil disse brukes i stedet for pluginen sin standardmal."
msgstr "Toutes les pages système suivent la hiérarchie de modèles standard de WordPress ; si votre thème possède ses propres modèles (par ex. <code>single-ka_course.php</code> ou <code>taxonomy-ka_coursecategory.php</code>), ceux-ci sont utilisés à la place du modèle par défaut de l'extension."

msgid "Alle taksonomisider (kategorier, kurssteder og instruktører) kan berikes med ekstra innhold som bilder, tekst og beskrivelser. Dette gjør at du kan tilpasse hver enkelt side med unikt innhold utover det som kommer fra Kursagenten."
msgstr "Toutes les pages de taxonomie (catégories, lieux de cours et instructeurs) peuvent être enrichies avec du contenu supplémentaire tel que des images, du texte et des descriptions. Cela vous permet de personnaliser chaque page avec un contenu unique au-delà de ce qui provient de Kursagenten."

msgid "Alle tilgjengelige kurssteder og datoer"
msgstr "Tous les lieux et dates de cours disponibles"

msgid "Alternativ farge for bokser:"
msgstr "Couleur alternative pour les boîtes :"

msgid "Alternativt bilde"
msgstr "Image alternative"

msgid "Annet"
msgstr "Autre"

msgid "Antall kolonner i rutenett:"
msgstr "Nombre de colonnes dans la grille :"

msgid "Antall kolonner på desktop."
msgstr "Nombre de colonnes sur ordinateur."

msgid "Antall kolonner på mobil."
msgstr "Nombre de colonnes sur tablette."

msgid "Antall kolonner på tablet."
msgstr "Nombre de colonnes sur mobile."

msgid "Antall kurs per side:"
msgstr "Nombre de cours par page :"

msgid "Antall kursdager"
msgstr "Nombre de jours de cours"

msgid "Automatisk (anbefalt)"
msgstr "Automatique (recommandé)"

msgid "Automatisk bruker responsivt srcset når mulig for skarpere bilder."
msgstr "Le mode automatique utilise un srcset responsive lorsque possible pour des images plus nettes."

msgid "Automenyer brukes når du vil at menyen automatisk skal vise taksonomier og/eller kurs uten at du manuelt må oppdatere menyelementer når noe endres."
msgstr "Les menus automatiques sont utilisés lorsque vous souhaitez que le menu affiche automatiquement les taxonomies et/ou les cours sans mettre à jour manuellement les éléments du menu lorsque quelque chose change."

msgid "Automenyer i WordPress-menyen"
msgstr "Menus automatiques dans le menu WordPress"

msgid "Av (håndteres av Rank Math Pro)"
msgstr "Désactivé (géré par Rank Math Pro)"

msgid "Avanserte innstillinger"
msgstr "Paramètres avancés"

msgid "Avbryt"
msgstr "Annuler"

msgid "Avrundet"
msgstr "Arrondi"

msgid "Avrundet søkefelt med ikon"
msgstr "Champ de recherche arrondi avec icône"

msgid "avrundet, rund, firkantet<br><strong>Standard</strong>: avrundet"
msgstr "rounded, circle, square<br><strong>Par défaut</strong> : rounded"

msgid "Avstand"
msgstr "Espacement"

msgid "Avstand rundt alle elementene, første verdi er topp og bunn, andre verdi er venstre og høyre."
msgstr "Espacement autour de tous les éléments ; la première valeur correspond au haut et au bas, la seconde à la gauche et à la droite."

msgid "Bakgrunn"
msgstr "Arrière-plan"

msgid "Bakgrunn fremhevede områder:"
msgstr "Arrière-plan pour les zones mises en évidence :"

msgid "Bakgrunn hover"
msgstr "Survol de l'arrière-plan"

msgid "Bakgrunn i toppfelt:"
msgstr "Arrière-plan dans la barre supérieure :"

msgid "Bakgrunnsbilde"
msgstr "Image d'arrière-plan"

msgid "Bakgrunnsbilde og overlay:"
msgstr "Image d'arrière-plan et superposition :"

msgid "Bakgrunnsfarge"
msgstr "Couleur d'arrière-plan"

msgid "Bakgrunnsfarge bak bilde"
msgstr "Couleur d'arrière-plan derrière l'image"

msgid "Bakgrunnskilde"
msgstr "Source de l'arrière-plan"

msgid "Bakgrunnstype:"
msgstr "Type d'arrière-plan :"

msgid "Base skriftstørrelse:"
msgstr "Taille de police de base :"

msgid "Bedriftsinformasjon"
msgstr "Informations sur l'entreprise"

msgid "Begge feltene må fylles ut"
msgstr "Les deux champs doivent être remplis"

msgid "Begrense innholdet med <strong>stedsfilter</strong> (f.eks. bare \"Oslo\" eller \"ikke-Oslo\")."
msgstr "Limiter le contenu avec le <strong>filtre de lieu</strong> (p. ex. uniquement « Oslo » ou « not Oslo »)."

msgid "Begrenser til termer med kurs på angitt sted. Start med \"ikke-\" for å ekskludere. La stå tom for alle."
