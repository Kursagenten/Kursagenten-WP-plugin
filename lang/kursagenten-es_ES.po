msgstr "Origen del fondo"

msgid "Bakgrunnstype:"
msgstr "Tipo de fondo:"

msgid "Base skriftstørrelse:"
msgstr "Tamaño base de fuente:"

msgid "Bedriftsinformasjon"
msgstr "Información de la empresa"

msgid "Begge feltene må fylles ut"
msgstr "Ambos campos deben rellenarse"

msgid "Begrense innholdet med <strong>stedsfilter</strong> (f.eks. bare \"Oslo\" eller \"ikke-Oslo\")."
msgstr "Limite el contenido con el <strong>filtro de ubicación</strong> (p. ej. solo «Oslo» o «not Oslo»)."

msgid "Begrenser til termer med kurs på angitt sted. Start med \"ikke-\" for å ekskludere. La stå tom for alle."
msgstr "Limita a términos con cursos en la ubicación especificada. Empiece con «not-» para excluir. Déjelo vacío para todos."

msgid "Behold H3 som standard med mindre du har en tydelig semantisk grunn til å endre."
msgstr "Mantenga H3 como predeterminado a menos que tenga una razón semántica clara para cambiarlo."

msgid "Berik innholdet ditt"
msgstr "Enriquecer su contenido"

msgid "Berike taksonomisider"
msgstr "Enriquecer páginas de taxonomía"

msgid "Beskrivelse"
msgstr "Descripción"

msgid "Betaling"
msgstr "Pago"

msgid "Betaling for kurs"
msgstr "Pago de cursos"

msgid "Betalingsside"
msgstr "Página de pago"

