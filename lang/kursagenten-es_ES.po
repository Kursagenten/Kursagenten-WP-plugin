msgstr "Campo de búsqueda redondeado con icono"

msgid "avrundet, rund, firkantet<br><strong>Standard</strong>: avrundet"
msgstr "redondeado, círculo, cuadrado<br><strong>Predeterminado</strong>: redondeado"

