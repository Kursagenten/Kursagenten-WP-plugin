msgstr "Fondo al pasar el cursor"

msgid "Bakgrunn i toppfelt:"
msgstr "Fondo en la barra superior:"

msgid "Bakgrunnsbilde"
msgstr "Imagen de fondo"

msgid "Bakgrunnsbilde og overlay:"
msgstr "Imagen de fondo y superposición:"

msgid "Bakgrunnsfarge"
msgstr "Color de fondo"

msgid "Bakgrunnsfarge bak bilde"
msgstr "Color de fondo detrás de la imagen"

