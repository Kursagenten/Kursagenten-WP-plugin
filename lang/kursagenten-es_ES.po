msgid " - side %d av %d"
msgstr " - página %d de %d"

msgid "-- Velg side --"
msgstr "-- Seleccionar página --"

msgid "– Brukes for feilsøking og oversikt"
msgstr "– Se usa para solución de problemas y vista general"

msgid "– side %1$d av %2$d"
msgstr "– página %1$d de %2$d"

msgid "\"Slug\" er den SEO-vennlige versjonen av url-en. Eksempel /kari-norman"
msgstr "«Slug» es la versión optimizada para SEO de la URL. Ejemplo /kari-norman"

msgid "\"Slug\" er den SEO-vennlige versjonen av url-en. Eksempel /mitt-kurs"
msgstr "«Slug» es la versión optimizada para SEO de la URL. Ejemplo /my-course"

msgid "\"Slug\" er den SEO-vennlige versjonen av url-en. Eksempel /oslo"
msgstr "«Slug» es la versión optimizada para SEO de la URL. Ejemplo /oslo"

msgid "(100-1000px)"
msgstr "(100-1000px)"

msgid "* Merk: Denne delen er fortsatt under utvikling."
msgstr "* Nota: Esta sección aún está en desarrollo."

msgid "%1$d %2$s valgt"
msgstr "%1$d %2$s seleccionados"

msgid "%1$s har samme slug som %2$s \"%3$s\""
msgstr "%1$s tiene el mismo slug que %2$s «%3$s»"

msgid "%d %s valgt"
msgstr "%d %s seleccionados"

msgid "← Tilbake til instruktører"
msgstr "← Volver a instructores"

msgid "← Tilbake til kurskategorier"
msgstr "← Volver a categorías de curso"

msgid "← Tilbake til kurssteder"
msgstr "← Volver a ubicaciones de curso"

msgid "+%d flere"
msgstr "+%d más"

msgid "<a href=\"admin.php?page=design\">Kursdesign</a> – Opprett ønskede sider for kurs, kategorier, steder og instruktører via \"Wordpress sider\". Kortkoder legges inn automatisk."
msgstr "<a href=\"admin.php?page=design\">Diseño de cursos</a> – Cree las páginas que necesita para cursos, categorías, ubicaciones e instructores mediante «Páginas de WordPress». Los shortcodes se insertan automáticamente."

msgid "<em>Skjul kategorien og alle tilhørende kurs</em> – både kategorien og alle kurs som er tagget med kategorien skjules helt fra kurslisten. Nyttig for interne kategorier som ikke skal være synlige for besøkende."
msgstr "<em>Ocultar la categoría y todos los cursos relacionados</em> – tanto la categoría como todos los cursos etiquetados con la categoría quedan completamente ocultos de la lista de cursos. Útil para categorías internas que no deben ser visibles para los visitantes."

msgid "<em>Skjul kun kategorien fra filter</em> – kategorien skjules fra filtervalgene, men kurs som er tagget med kategorien vises fortsatt i kurslisten under sine andre kategorier. Nyttig for «brede» tagger som ikke gir mening som filter (f.eks. «Foredrag», «HMS og sikkerhetskurs»)."
msgstr "<em>Ocultar solo la categoría del filtro</em> – la categoría se oculta de las opciones de filtro, pero los cursos etiquetados con la categoría siguen apareciendo en la lista de cursos bajo sus otras categorías. Útil para etiquetas «amplias» que no tienen sentido como filtros (p. ej. «Conferencias», «Cursos HMS y seguridad»)."

msgid "<em>Vis</em> – kategorien vises i filteret og kursene vises i listen (standard)."
msgstr "<em>Mostrar</em> – la categoría aparece en el filtro y los cursos aparecen en la lista (predeterminado)."

msgid "<p><strong>Bruk Kursagenten instruktørprofil i stedet:</strong></p><ol><li>Slett denne instruktøren</li><li>Lagre et kurs i Kursagenten hvor instruktøren er lagt inn</li></ol>"
msgstr "<p><strong>Use el perfil de instructor de Kursagenten en su lugar:</strong></p><ol><li>Elimine este instructor</li><li>Guarde un curso en Kursagenten donde se añada el instructor</li></ol>"

msgid "<p><strong>Gå tilbake til Kursagenten-data:</strong></p><ol><li>Deaktiver \"Overstyr profil fra Kursagenten\" knappen</li><li>Oppdater instruktørprofilen i Kursagenten</li><li>Profilen oppdateres her. Merk: instruktøren må være knyttet til et kurs for at dataene skal bli hentet over.</li></ol><p>- Bruker du data fra Kursagenten, slipper du å holde dem oppdatert to steder.<br>- En instruktør som er opprettet i Kursagenten med det samme navnet, vil automatisk bli slått sammen med denne instruktøren.</p>"
msgstr "<p><strong>Volver a los datos de Kursagenten:</strong></p><ol><li>Desactive el botón «Sustituir perfil de Kursagenten»</li><li>Actualice el perfil del instructor en Kursagenten</li><li>El perfil se actualiza aquí. Nota: el instructor debe estar vinculado a un curso para que se obtengan los datos.</li></ol><p>- Si usa datos de Kursagenten, no necesita mantenerlos actualizados en dos lugares.<br>- Un instructor creado en Kursagenten con el mismo nombre se fusionará automáticamente con este instructor.</p>"

msgid "<strong>Advarsel:</strong> Navn og slug på kurssteder kan ikke endres her. Du kan endre navnet under <a href=\"%s\">Synkronisering</a>."
msgstr "<strong>Advertencia:</strong> El nombre y el slug de las ubicaciones de curso no se pueden cambiar aquí. Puede cambiar el nombre en <a href=\"%s\">Sincronización</a>."

msgid "<strong>Alternativt bilde:</strong> Et ekstra bilde som kan brukes på instruktørsiden."
msgstr "<strong>Imagen alternativa:</strong> Una imagen adicional que se puede usar en la página del instructor."

msgid "<strong>Antall per side:</strong> Velg antall kurs som skal vises per side."
msgstr "<strong>Número por página:</strong> Elija cuántos cursos mostrar por página."

msgid "<strong>Automatisk opprettelse:</strong> Gå til <a href=\"admin.php?page=design#section-systemsider\">Kursdesign → Wordpress sider</a> og klikk på \"Opprett side\" for hver side du trenger. Kortkoden legges inn automatisk."
msgstr "<strong>Creación automática:</strong> Vaya a <a href=\"admin.php?page=design#section-systemsider\">Diseño de cursos → Páginas de WordPress</a> y haga clic en «Crear página» para cada página que necesite. El shortcode se inserta automáticamente."

msgid "<strong>Automatisk opprydding:</strong> Det kjøres også en automatisk nattlig opprydding klokken 03:00 hver natt, så det er ikke alltid nødvendig å kjøre opprydding manuelt. Bruk manuell opprydding hvis du har mange utløpte kursdatoer som vises på nettsiden og ønsker å rydde opp umiddelbart."
msgstr "<strong>Limpieza automática:</strong> También se ejecuta una limpieza nocturna automática a las 03:00 cada noche, por lo que la limpieza manual no siempre es necesaria. Use la limpieza manual si tiene muchas fechas de curso caducadas mostradas en el sitio web y desea limpiar inmediatamente."

msgid "<strong>Automatisk synkronisering via webhooks:</strong> Når webhooks er konfigurert, oppdateres kursene automatisk når de endres i Kursagenten. Dette er den anbefalte metoden for løpende oppdateringer."
msgstr "<strong>Sincronización automática mediante webhooks:</strong> Cuando los webhooks están configurados, los cursos se actualizan automáticamente cuando cambian en Kursagenten. Este es el método recomendado para actualizaciones continuas."

msgid "<strong>Automatisk:</strong> Steder blir automatisk tilordnet til regioner basert på fylke når regioner er aktivert."
msgstr "<strong>Automático:</strong> Las ubicaciones se asignan automáticamente a regiones según la provincia cuando las regiones están activadas."

msgid "<strong>Avkrysning før synkronisering:</strong> Når du klikker på \"Hent alle kurs fra Kursagenten\", kan du kryss av for \"Rydd opp i kurs etter synkronisering\". Dette kjører opprydding automatisk etter at synkroniseringen er fullført. <strong>NB:</strong> Opprydding tar 3-5 minutter ekstra."
msgstr "<strong>Casilla antes de la sincronización:</strong> Cuando hace clic en «Obtener todos los cursos de Kursagenten», puede marcar «Limpiar cursos después de la sincronización». Esto ejecuta la limpieza automáticamente tras completar la sincronización. <strong>Nota:</strong> La limpieza tarda 3–5 minutos adicionales."

msgid "<strong>Bilde:</strong> Et bilde som vises på stedssiden og i lister."
msgstr "<strong>Imagen:</strong> Una imagen mostrada en la página de ubicación y en listas."

msgid "<strong>Bilde:</strong> Last opp et hovedbilde som vises på taksonomisiden og i lister."
msgstr "<strong>Imagen:</strong> Suba una imagen principal mostrada en la página de taxonomía y en listas."

msgid "<strong>Bilder:</strong> Bruk plassholder-bilder via kortkodene om du mangler bilder."
msgstr "<strong>Imágenes:</strong> Use imágenes de marcador de posición mediante shortcodes si le faltan imágenes."

msgid "<strong>Bredde:</strong> Velg om du vil bruke temaets standardbredde eller full bredde. Stort sett vil standardbredde fungerer som tiltenkt."
msgstr "<strong>Ancho:</strong> Elija si usar el ancho predeterminado del tema o ancho completo. En la mayoría de los casos, el ancho predeterminado funciona como se espera."

msgid "<strong>Bruk i kortkoder:</strong> Du kan filtrere kurssteder basert på region i kortkoden <code class=\"copytext\">[kurssteder]</code>:"
msgstr "<strong>Uso en shortcodes:</strong> Puede filtrar ubicaciones de curso por región en el shortcode <code class=\"copytext\">[kurssteder]</code>:"

msgid "<strong>Bygg ditt eget design</strong> er aktivt. Du kan fortsatt styre kursdata-visning under."
msgstr "<strong>Construya su propio diseño</strong> está activo. Aún puede controlar la visualización de datos del curso a continuación."

msgid "<strong>Bygg ditt eget design</strong> er aktivt. Kursagenten bruker WordPress sitt malhierarki, slik at tema/page builder kan styre oppsett."
msgstr "<strong>Construya su propio diseño</strong> está activo. Kursagenten usa la jerarquía de plantillas de WordPress para que su tema/page builder pueda controlar el diseño."

msgid "<strong>Byggeblokker kommer:</strong> vi planlegger moduler for blant annet kursliste med kurssteder/lenker og informasjon om kommende kurs."
msgstr "<strong>Bloques próximamente:</strong> estamos planificando módulos para listas de cursos con ubicaciones/enlaces de curso e información sobre cursos próximos."

msgid "<strong>Cache:</strong> Tøm cache hvis du ikke ser endringer umiddelbart."
msgstr "<strong>Caché:</strong> Borre la caché si no ve los cambios inmediatamente."

msgid "<strong>Designendringer:</strong> Hvis designendringer ikke vises, kan det være nødvendig å tømme cache og oppdatere permalenker."
msgstr "<strong>Cambios de diseño:</strong> Si los cambios de diseño no aparecen, puede que necesite borrar la caché y actualizar los enlaces permanentes."

msgid "<strong>E-post:</strong> Instruktørens e-postadresse."
msgstr "<strong>Correo electrónico:</strong> La dirección de correo electrónico del instructor."

msgid "<strong>Egen opprydding:</strong> Du kan også kjøre opprydding separat ved å klikke på knappen \"Rydd opp i kurs\" på <a href=\"admin.php?page=kursinnstillinger\">Synkronisering</a>-siden. Dette er nyttig hvis du bare ønsker å rydde opp uten å synkronisere alle kursene på nytt."
msgstr "<strong>Limpieza separada:</strong> También puede ejecutar la limpieza por separado haciendo clic en el botón «Limpiar cursos» en la página de <a href=\"admin.php?page=kursinnstillinger\">Sincronización</a>. Esto es útil si solo desea limpiar sin volver a sincronizar todos los cursos."

msgid "<strong>Eget innhold over/under:</strong> Du kan legge inn vanlig innhold i editoren over og under kortkoden for å skrive en introduksjon, legge til bilder eller annen informasjon."
msgstr "<strong>Contenido personalizado arriba/abajo:</strong> Puede añadir contenido normal en el editor encima y debajo del shortcode para escribir una introducción, añadir imágenes u otra información."

msgid "<strong>Ekstra felter:</strong> Spesifikke felter avhengig av taksonomitypen (se nedenfor)."
msgstr "<strong>Campos adicionales:</strong> Campos específicos según el tipo de taxonomía (véase abajo)."

msgid "<strong>Enkel - kun tittel og kort beskrivelse:</strong> Tittel og kort beskrivelse, deretter kursliste. Egnet når du ikke har bilder eller utvidet beskrivelse."
msgstr "<strong>Simple – solo título y descripción breve:</strong> Título y descripción breve, luego lista de cursos. Adecuado cuando no tiene imágenes o descripción ampliada."

msgid "<strong>Enkle kort:</strong> Hvite kort med overskrift og tekst. Viser neste tilgjengelige dato for kursene. Mulig å velge antall kolonner for desktop, tablet og mobil."
msgstr "<strong>Tarjetas simples:</strong> Tarjetas blancas con encabezado y texto. Muestra la próxima fecha disponible para los cursos. Puede elegir el número de columnas para escritorio, tableta y móvil."

msgid "<strong>Felles designmal:</strong> Alle taksonomier bruker samme designmal."
msgstr "<strong>Plantilla de diseño compartida:</strong> Todas las taxonomías usan la misma plantilla de diseño."

msgid "<strong>Grid:</strong> Et rutenett med kurskort i flere kolonner. Mulig å velge antall kolonner for desktop, tablet og mobil."
msgstr "<strong>Cuadrícula:</strong> Una cuadrícula de tarjetas de curso en varias columnas. Puede elegir el número de columnas para escritorio, tableta y móvil."

msgid "<strong>Hovedbilde:</strong> Et bilde som vises på kategorisiden og i lister."
msgstr "<strong>Imagen principal:</strong> Una imagen mostrada en la página de categoría y en listas."

msgid "<strong>Hva er kortkoder?</strong> Kortkoder er små koder du plasserer i innhold (sider/innlegg) for å vise dynamiske lister og komponenter fra pluginen."
msgstr "<strong>¿Qué son los shortcodes?</strong> Los shortcodes son pequeños códigos que coloca en el contenido (páginas/entradas) para mostrar listas dinámicas y componentes del plugin."

msgid "<strong>Hvor brukes de?</strong> Vanligvis på egne sider eller innlegg (f.eks. «Kurs», «Kurskategorier», «Kurssteder», «Instruktører»). Du kan også bruke dem i menyen eller widgets."
msgstr "<strong>¿Dónde se usan?</strong> Normalmente en páginas o entradas dedicadas (p. ej. «Cursos», «Categorías de curso», «Ubicaciones de curso», «Instructores»). También puede usarlos en menús o widgets."

msgid "<strong>Ikon:</strong> Et alternativt bilde som kan brukes i stedet for hovedbilde i lister. Her er det fint å laste opp png-ikoner (bruk <code>kilde=ikon</code> i kortkoden)."
msgstr "<strong>Icono:</strong> Una imagen alternativa que se puede usar en lugar de la imagen principal en listas. Los iconos PNG funcionan bien aquí (use <code>kilde=ikon</code> en el shortcode)."

msgid "<strong>Instruktører</strong> – Inneholder <code class=\"copytext\">[instruktorer]</code> for å vise alle instruktører."
msgstr "<strong>Instructores</strong> – Contiene <code class=\"copytext\">[instruktorer]</code> para mostrar todos los instructores."

msgid "<strong>Kompakt:</strong> En mer kompakt listevisning med mindre mellomrom. Uten bakgrunn, og med færre kurselementer"
msgstr "<strong>Compacto:</strong> Una vista de lista más compacta con menos espaciado. Sin fondo y con menos elementos de curso."

msgid "<strong>Kort beskrivelse:</strong> En kort tekst som kan vises i lister og oversikter. Vises ofte direkte under overskriften."
msgstr "<strong>Descripción breve:</strong> Un texto breve que se puede mostrar en listas y vistas generales. A menudo se muestra directamente debajo del encabezado."

msgid "<strong>Kort beskrivelse:</strong> En kort tekst som kan vises i lister."
msgstr "<strong>Descripción breve:</strong> Un texto breve que se puede mostrar en listas."

msgid "<strong>Kort beskrivelse:</strong> En kort tekst som kan vises i lister. Vises ofte direkte under overskriften."
msgstr "<strong>Descripción breve:</strong> Un texto breve que se puede mostrar en listas. A menudo se muestra directamente debajo del encabezado."

msgid "<strong>Kurs</strong> – Inneholder <code class=\"copytext\">[kursliste]</code> for å vise alle kurs med filtre."
msgstr "<strong>Cursos</strong> – Contiene <code class=\"copytext\">[kursliste]</code> para mostrar todos los cursos con filtros."

msgid "<strong>Kurskategorier</strong> – Inneholder <code class=\"copytext\">[kurskategorier]</code> for å vise alle kategorier."
msgstr "<strong>Categorías de curso</strong> – Contiene <code class=\"copytext\">[kurskategorier]</code> para mostrar todas las categorías."

msgid "<strong>Kursliste (kun for kurskategorier):</strong> Tre alternativer styrer hvordan kategorien påvirker kurslisten:"
msgstr "<strong>Lista de cursos (solo categorías de curso):</strong> Tres opciones controlan cómo la categoría afecta a la lista de cursos:"

msgid "<strong>Kursliste med filter </strong><span class=\"smal\"><span class=\"copytext\">[kursliste]</span></span><br><span class=\"copytext small\">[kursliste kategori=\"web\" sted=\"oslo\" måned=\"9\" språk=\"norsk\" list_type=\"grid\" filter=\"topp\" knapper=\"signup_link\" bilder=\"yes\" vis=\"-sluttdato\" st=sted/st=ikke-sted klasse=\"min-klasse\"]</span>"
msgstr "<strong>Lista de cursos con filtro </strong><span class=\"smal\"><span class=\"copytext\">[kursliste]</span></span><br><span class=\"copytext small\">[kursliste kategori=\"web\" sted=\"oslo\" måned=\"9\" språk=\"norsk\" list_type=\"grid\" filter=\"topp\" knapper=\"signup_link\" bilder=\"yes\" vis=\"-sluttdato\" st=sted/st=ikke-sted klasse=\"min-klasse\"]</span>"

msgid "<strong>Kurssteder opprettes automatisk</strong> når du synkroniserer kurs fra Kursagenten. Du kan ikke legge til kurssteder manuelt her."
msgstr "<strong>Las ubicaciones de curso se crean automáticamente</strong> cuando sincroniza cursos desde Kursagenten. No puede añadir ubicaciones de curso manualmente aquí."

msgid "<strong>Kurssteder</strong> – Inneholder <code class=\"copytext\">[kurssteder]</code> for å vise alle kurssteder."
msgstr "<strong>Ubicaciones de curso</strong> – Contiene <code class=\"copytext\">[kurssteder]</code> para mostrar todas las ubicaciones de curso."

msgid "<strong>Layout og struktur:</strong> Hvor elementene plasseres på siden (header, innhold, sidekolonne, footer)."
msgstr "<strong>Diseño y estructura:</strong> Dónde se colocan los elementos en la página (encabezado, contenido, barra lateral, pie de página)."

msgid "<strong>Layout:</strong> Velg designet på siden. Dette styrer hvor/hvordan tittel, tekst, hovedbilde og kursliste vises."
msgstr "<strong>Diseño:</strong> Elija el diseño de la página. Esto controla dónde/cómo se muestran el título, el texto, la imagen principal y la lista de cursos."

msgid "<strong>Layout</strong> bestemmer oppsettet av elementer på siden (header, kolonner, hooks).</br><strong>Listedesign</strong> bestemmer hvordan kursene vises i listen (standard, rutenett, ren, kompakt, dato og tittel). </br><strong>Visningstype</strong> bestemmer om du vil vise hovedkurs eller alle kursdatoer."
msgstr "<strong>Diseño</strong> determina la disposición de los elementos en la página (encabezado, columnas, hooks).</br><strong>Diseño de lista</strong> determina cómo se muestran los cursos en la lista (predeterminado, cuadrícula, simple, compacto, fecha y título). </br><strong>Tipo de visualización</strong> determina si mostrar cursos principales o todas las fechas de curso."

msgid "<strong>Liste med instruktører </strong><span class=\"smal\"><span class=\"copytext\">[instruktorer]</span></span><br><span class=\"copytext small\" style=\"color:#666\">[instruktorer layout=\"stablet/rad/liste\" grid=3 gridtablet=2 gridmobil=1 radavstand=\"1rem\" stil=\"standard/kort\" bildestr=\"100px\" bildeform=\"avrundet/rund/firkantet/10px\" bildeformat=\"4/3\" overskrift=\"h3\" fontmin=\"13px\" fontmaks=\"15px\" avstand=\"2em .5em\" skygge=\"ja\" skjul=\"Iris,Anna\" utdrag=\"ja\" beskrivelse=\"ja\" klasse=\"min-klasse\"]</span>"
msgstr "<strong>Lista de instructores </strong><span class=\"smal\"><span class=\"copytext\">[instruktorer]</span></span><br><span class=\"copytext small\" style=\"color:#666\">[instruktorer layout=\"stablet/rad/liste\" grid=3 gridtablet=2 gridmobil=1 radavstand=\"1rem\" stil=\"standard/kort\" bildestr=\"100px\" bildeform=\"avrundet/rund/firkantet/10px\" bildeformat=\"4/3\" overskrift=\"h3\" fontmin=\"13px\" fontmaks=\"15px\" avstand=\"2em .5em\" skygge=\"ja\" skjul=\"Iris,Anna\" utdrag=\"ja\" beskrivelse=\"ja\" klasse=\"min-klasse\"]</span>"

msgid "<strong>Liste med kurskategorier </strong><span class=\"smal\"><span class=\"copytext\">[kurskategorier]</span></span><br><span class=\"copytext small\" style=\"color:#666\">[kurskategorier kilde=\"bilde/ikon\" layout=\"stablet/rad/liste\" grid=3 gridtablet=2 gridmobil=1  radavstand=\"1rem\" stil=\"standard/kort\" bildestr=\"100px\" bildeform=\"avrundet/rund/firkantet/10px\" bildeformat=\"4/3\" overskrift=\"h3\" fontmin=\"13\" fontmaks=\"18\" avstand=\"2em .5em\" skygge=\"ja\" vis=\"hovedkategorier/subkategorier/slug/standard\" st=sted/st=ikke-sted utdrag=\"ja\" klasse=\"min-klasse\"]</span>"
msgstr "<strong>Lista de categorías de curso </strong><span class=\"smal\"><span class=\"copytext\">[kurskategorier]</span></span><br><span class=\"copytext small\" style=\"color:#666\">[kurskategorier kilde=\"bilde/ikon\" layout=\"stablet/rad/liste\" grid=3 gridtablet=2 gridmobil=1  radavstand=\"1rem\" stil=\"standard/kort\" bildestr=\"100px\" bildeform=\"avrundet/rund/firkantet/10px\" bildeformat=\"4/3\" overskrift=\"h3\" fontmin=\"13\" fontmaks=\"18\" avstand=\"2em .5em\" skygge=\"ja\" vis=\"hovedkategorier/subkategorier/slug/standard\" st=sted/st=ikke-sted utdrag=\"ja\" klasse=\"min-klasse\"]</span>"

msgid "<strong>Liste med kurssteder </strong><span class=\"smal\"><span class=\"copytext\">[kurssteder]</span></span><br><span class=\"copytext small\" style=\"color:#666\">[kurssteder layout=\"stablet/rad/liste\" grid=3 gridtablet=2 gridmobil=1 radavstand=\"1rem\" stil=\"standard/kort\" bildestr=\"100px\" bildeform=\"avrundet/rund/firkantet/10px\" bildeformat=\"4/3\" overskrift=\"h3\" fontmin=\"13px\" fontmaks=\"15px\" avstand=\"2em .5em\" skygge=\"ja\" utdrag=\"ja\" vis=\"standard/alta,oslo,bergen\" region=\"østlandet\" stedinfo=\"ja\" klasse=\"min-klasse\"]</span>"
msgstr "<strong>Lista de ubicaciones de curso </strong><span class=\"smal\"><span class=\"copytext\">[kurssteder]</span></span><br><span class=\"copytext small\" style=\"color:#666\">[kurssteder layout=\"stablet/rad/liste\" grid=3 gridtablet=2 gridmobil=1 radavstand=\"1rem\" stil=\"standard/kort\" bildestr=\"100px\" bildeform=\"avrundet/rund/firkantet/10px\" bildeformat=\"4/3\" overskrift=\"h3\" fontmin=\"13px\" fontmaks=\"15px\" avstand=\"2em .5em\" skygge=\"ja\" utdrag=\"ja\" vis=\"standard/alta,oslo,bergen\" region=\"østlandet\" stedinfo=\"ja\" klasse=\"min-klasse\"]</span>"

msgid "<strong>Listedesign:</strong> Velg designet på kurslisten (standard, rutenett, kompakt, enkle kort...)"
msgstr "<strong>Diseño de lista:</strong> Elija el diseño de la lista de cursos (predeterminado, cuadrícula, compacto, tarjetas simples...)"

msgid "<strong>Listedesign:</strong> Velg listedesign (standard, rutenett, kompakt, enkel liste, enkle kort)."
msgstr "<strong>Diseño de lista:</strong> Elija el diseño de lista (predeterminado, cuadrícula, compacto, lista simple, tarjetas simples)."

msgid "<strong>Listedesign</strong> bestemmer hvordan kursene vises i listen (standard, rutenett, ren, kompakt, dato og tittel)."
msgstr "<strong>Diseño de lista</strong> determina cómo se muestran los cursos en la lista (predeterminado, cuadrícula, simple, compacto, fecha y título)."

msgid "<strong>Manuell synkronisering:</strong> Gå til <a href=\"admin.php?page=kursinnstillinger\">Synkronisering</a> og klikk på \"Hent alle kurs fra Kursagenten\". Dette bør gjøres første gang du setter opp pluginen, og ved behov for å oppdatere alle kursene samtidig."
msgstr "<strong>Sincronización manual:</strong> Vaya a <a href=\"admin.php?page=kursinnstillinger\">Sincronización</a> y haga clic en «Obtener todos los cursos de Kursagenten». Esto debe hacerse la primera vez que configure el plugin, y cuando necesite actualizar todos los cursos a la vez."

msgid "<strong>Manuelt:</strong> Du kan endre region for individuelle steder ved å redigere kursstedet i <a href=\"edit-tags.php?taxonomy=ka_course_location&post_type=ka_course\">Kurssteder</a>-oversikten."
msgstr "<strong>Manual:</strong> Puede cambiar la región de ubicaciones individuales editando la ubicación de curso en la vista general de <a href=\"edit-tags.php?taxonomy=ka_course_location&post_type=ka_course\">Ubicaciones de curso</a>."

msgid "<strong>Merk:</strong> Regioner må være aktivert for at filtreringen skal fungere. Du kan også endre region for individuelle kurssteder ved å redigere kursstedet i <a href=\"edit-tags.php?taxonomy=ka_course_location&post_type=ka_course\">Kurssteder</a>-oversikten."
msgstr "<strong>Nota:</strong> Las regiones deben estar activadas para que el filtrado funcione. También puede cambiar la región de ubicaciones de curso individuales editando la ubicación en la vista general de <a href=\"edit-tags.php?taxonomy=ka_course_location&post_type=ka_course\">Ubicaciones de curso</a>."

msgid "<strong>Navn:</strong> Instruktørens navn (kan deles opp i fornavn og etternavn)."
msgstr "<strong>Nombre:</strong> El nombre del instructor (se puede dividir en nombre y apellidos)."

msgid "<strong>Navn:</strong> Kategorinavnet (kommer fra Kursagenten, bør ikke endres)."
msgstr "<strong>Nombre:</strong> El nombre de la categoría (procede de Kursagenten, no debe cambiarse)."

msgid "<strong>Navn:</strong> Stedsnavnet (kommer fra Kursagenten, men kan endres via navnendring-funksjonen)."
msgstr "<strong>Nombre:</strong> El nombre de la ubicación (procede de Kursagenten, pero se puede cambiar mediante la función de cambio de nombre)."

msgid "<strong>Navnendring på kurssteder:</strong><br>Du kan endre navn på kurssteder under <a href=\"%s\">Synkronisering → Navnendring på kurssteder</a>. Når du endrer navn på et sted, blir også slugs (nettadressen) på kursene som har dette stedet oppdatert.<br> Det gamle stedet blir ikke slettet, men blir ikke lenger synlig på nettsiden."
msgstr "<strong>Cambio de nombre de ubicaciones de curso:</strong><br>Puede cambiar los nombres de ubicación de curso en <a href=\"%s\">Sincronización → Cambios de nombre de ubicación de curso</a>. Cuando cambia el nombre de una ubicación, los slugs (URLs) de los cursos con esta ubicación también se actualizan.<br> La ubicación antigua no se elimina, pero ya no es visible en el sitio web."

msgid "<strong>Når bør du bruke kortkoder?</strong> Hvis du bygger sidene med Elementor eller andre page builders, vil kortkoder sannsynligvis være det du må bruke."
msgstr "<strong>¿Cuándo debe usar shortcodes?</strong> Si construye páginas con Elementor u otros page builders, probablemente necesitará usar shortcodes."

msgid "<strong>Obs:</strong> For at brukerne skal kunne slå filteret av og på, må du dra <em>«Ledige kurs»</em> inn i «Filtre i venstre kolonne» eller «Filtre over kurslisten» under Filterinnstillinger."
msgstr "<strong>Nota:</strong> Para que los usuarios puedan activar y desactivar el filtro, debe arrastrar <em>«Cursos disponibles»</em> a «Filtros en columna izquierda» o «Filtros encima de la lista de cursos» en Ajustes de filtro."

msgid "<strong>OBS!</strong> Fyll inn <a href=\"#kursagenten-innstillinger\" style=\"color:white; text-decoration: underline;\">innstillinger fra Kursagenten</a> før du henter alle kursene dine (synkroniser alle kurs)."
msgstr "<strong>¡NOTA!</strong> Introduzca los <a href=\"#kursagenten-innstillinger\" style=\"color:white; text-decoration: underline;\">ajustes de Kursagenten</a> antes de obtener todos sus cursos (sincronizar todos los cursos)."

msgid "<strong>Overstyr profil fra Kursagenten:</strong> Aktiver denne for å kunne redigere navn, e-post og telefon. Når aktivert, vil ikke disse feltene oppdateres automatisk fra Kursagenten ved synkronisering."
msgstr "<strong>Sustituir perfil de Kursagenten:</strong> Active esto para editar nombre, correo electrónico y teléfono. Cuando está activado, estos campos no se actualizarán automáticamente desde Kursagenten durante la sincronización."

msgid "<strong>Overstyr profilbilde:</strong> Aktiver denne for å bruke et eget opplastet bilde i stedet for bildet fra Kursagenten."
msgstr "<strong>Sustituir imagen de perfil:</strong> Active esto para usar su propia imagen subida en lugar de la imagen de Kursagenten."

msgid "<strong>Page builder (Kadence Elements, Elementor m.fl.):</strong> Hvis du vil styre single/archive/taksonomi med page builder-betingelser, gå til <a href=\"admin.php?page=design#section-enkeltkurs\">Kursdesign → Enkeltkurs</a> og aktiver <em>Bruk WordPress sitt standard malhierarki</em>. Da lar pluginen tema/page builder velge mal uten å tvinge pluginens egne layout-filer."
msgstr "<strong>Page builder (Kadence Elements, Elementor, etc.):</strong> Si desea controlar single/archive/taxonomy con condiciones de page builder, vaya a <a href=\"admin.php?page=design#section-enkeltkurs\">Diseño de cursos → Curso individual</a> y active <em>Usar jerarquía de plantillas predeterminada de WordPress</em>. El plugin entonces deja que el tema/page builder elija la plantilla sin forzar los archivos de diseño propios del plugin."

msgid "<strong>Permalenker:</strong> Ved endring av URL-innstillinger, lagre «Permalenker» på nytt."
msgstr "<strong>Enlaces permanentes:</strong> Al cambiar los ajustes de URL, guarde «Enlaces permanentes» de nuevo."

msgid "<strong>Plassering:</strong> Filtrene velges ved å dra dem til korrekt plassering. Du kan velge å vise dem til venstre for kurslisten og/eller over kurslisten."
msgstr "<strong>Ubicación:</strong> Elija filtros arrastrándolos a la posición correcta. Puede mostrarlos a la izquierda de la lista de cursos y/o encima de la lista de cursos."

msgid "<strong>Profil - rundt bilde og tittel:</strong> Rundt bilde, deretter tittel og beskrivelse, deretter kursliste"
msgstr "<strong>Perfil – alrededor de imagen y título:</strong> Alrededor de la imagen, luego título y descripción, luego lista de cursos."

msgid "<strong>Profilbilde:</strong> Et hovedbilde som vises på instruktørsiden og i lister. Dette kan være fra Kursagenten eller et eget opplastet bilde."
msgstr "<strong>Imagen de perfil:</strong> Una imagen principal mostrada en la página del instructor y en listas. Puede ser de Kursagenten o su propia imagen subida."

msgid "<strong>Region:</strong> (Hvis regioner er aktivert) Velg hvilken region stedet tilhører."
msgstr "<strong>Región:</strong> (Si las regiones están activadas) Elija a qué región pertenece la ubicación."

msgid "<strong>Regioner:</strong><br>Du kan aktivere og administrere regioner under <a href=\"%s\">Synkronisering → Regioner</a>."
msgstr "<strong>Regiones:</strong><br>Puede activar y gestionar regiones en <a href=\"%s\">Sincronización → Regiones</a>."

msgid "<strong>Regioner:</strong><br>Regioner er aktivert. Du kan administrere regioninndelingen under <a href=\"%s\">Synkronisering → Regioner</a>. Tilhørighet til en region kan endres under hvert kurssted."
msgstr "<strong>Regiones:</strong><br>Las regiones están activadas. Puede gestionar la división regional en <a href=\"%s\">Sincronización → Regiones</a>. La asignación regional se puede cambiar para cada ubicación de curso."

msgid "<strong>Rekkefølge på elementer:</strong> Hvilken rekkefølge informasjonen vises i (introtekst, hovedinnhold, kursdatoer, instruktører, osv.)."
msgstr "<strong>Orden de elementos:</strong> El orden en que se muestra la información (texto introductorio, contenido principal, fechas de curso, instructores, etc.)."

msgid "<strong>Rekkefølge:</strong> Du kan også dra i filtrene for å endre rekkefølgen de vises i."
msgstr "<strong>Orden:</strong> También puede arrastrar filtros para cambiar el orden en que se muestran."

msgid "<strong>Ren og enkel liste:</strong> Basert på Standard liste, men uten bakgrunn, og med færre kurselementer"
msgstr "<strong>Lista limpia y simple:</strong> Basada en la lista estándar, pero sin fondo y con menos elementos de curso."

msgid "<strong>Separate designmaler:</strong> Aktiver dette for å kunne velge forskjellige designmaler for kategorier, steder og instruktører."
msgstr "<strong>Plantillas de diseño separadas:</strong> Active esto para elegir distintas plantillas de diseño para categorías, ubicaciones e instructores."

msgid "<strong>Skjul i automenyer:</strong> Når aktivert, skjules kategorien i autogenererte menyer som bruker kortkoden <code>[ka-meny]</code>. Dette er nyttig hvis du har kategorier som ikke skal vises i hovedmenyen."
msgstr "<strong>Ocultar en menús automáticos:</strong> Cuando está activado, la categoría se oculta en menús autogenerados que usan el shortcode <code>[ka-meny]</code>. Útil si tiene categorías que no deben aparecer en el menú principal."

msgid "<strong>Skjul i oversiktslister:</strong> Når aktivert, skjules kategorien i kortkoder som <code>[kurskategorier]</code> og lignende lister. Kategorien vil fortsatt være tilgjengelig direkte via URL."
msgstr "<strong>Ocultar en listas de vista general:</strong> Cuando está activado, la categoría se oculta en shortcodes como <code>[kurskategorier]</code> y listas similares. La categoría seguirá siendo accesible directamente mediante URL."

msgid "<strong>Slug:</strong> URL-vennlig versjon av navnet (bør ikke endres da det kan føre til ødelagte lenker)."
msgstr "<strong>Slug:</strong> Versión amigable para URL del nombre (no debe cambiarse ya que puede romper enlaces)."

msgid "<strong>Slug:</strong> URL-vennlig versjon av navnet (oppdateres automatisk ved navnendring)."
msgstr "<strong>Slug:</strong> Versión amigable para URL del nombre (se actualiza automáticamente cuando cambia el nombre)."

msgid "<strong>Standard - med bilde og beskrivelse:</strong> Tittel og beskrivelse, deretter bilde og beskrivelse, deretter kursliste"
msgstr "<strong>Predeterminado – con imagen y descripción:</strong> Título y descripción, luego imagen y descripción, luego lista de cursos."

msgid "<strong>Standard:</strong> 1 kolonne"
msgstr "<strong>Predeterminado:</strong> 1 columna"

msgid "<strong>Standard:</strong> 100px"
msgstr "<strong>Predeterminado:</strong> 100px"

msgid "<strong>Standard:</strong> 1rem"
msgstr "<strong>Predeterminado:</strong> 1rem"

msgid "<strong>Standard:</strong> 2 kolonner"
msgstr "<strong>Predeterminado:</strong> 2 columnas"

msgid "<strong>Standard:</strong> 2em .5em"
msgstr "<strong>Predeterminado:</strong> 2em .5em"

msgid "<strong>Standard:</strong> 3 kolonner"
msgstr "<strong>Predeterminado:</strong> 3 columnas"

msgid "<strong>Standard:</strong> En tradisjonell listevisning med kurskort, ett kurs per rad/boks."
msgstr "<strong>Predeterminado:</strong> Una vista de lista tradicional con tarjetas de curso, un curso por fila/caja."

msgid "<strong>Synkronisering:</strong> Hvis kurs ikke oppdateres automatisk, sjekk at webhooks er konfigurert korrekt i Kursagenten."
msgstr "<strong>Sincronización:</strong> Si los cursos no se actualizan automáticamente, compruebe que los webhooks estén configurados correctamente en Kursagenten."

msgid "<strong>Tagger eller lister:</strong> Filtrene kan velges som tagger eller avkrysningsliste. Tagger er knapper som velger ett filter av gangen, og avkrysningsliste er en liste som kan velge flere filter samtidig."
msgstr "<strong>Etiquetas o listas:</strong> Los filtros se pueden mostrar como etiquetas o casillas de verificación. Las etiquetas son botones que seleccionan un filtro a la vez; las casillas permiten seleccionar varios filtros a la vez."

msgid "<strong>Telefon:</strong> Instruktørens telefonnummer."
msgstr "<strong>Teléfono:</strong> El número de teléfono del instructor."

msgid "<strong>Test:</strong> Besøk frontend og se at det ser ut som det skal."
msgstr "<strong>Prueba:</strong> Visite el frontend y compruebe que se ve como se espera."

msgid "<strong>Utvidet beskrivelse:</strong> En lengre tekst med HTML-formatering som vises på instruktørsiden."
msgstr "<strong>Descripción ampliada:</strong> Un texto más largo con formato HTML mostrado en la página del instructor."

msgid "<strong>Utvidet beskrivelse:</strong> En lengre tekst med HTML-formatering som vises på kategorisiden."
msgstr "<strong>Descripción ampliada:</strong> Un texto más largo con formato HTML mostrado en la página de categoría."

msgid "<strong>Utvidet beskrivelse:</strong> En lengre tekst med HTML-formatering som vises på stedssiden."
msgstr "<strong>Descripción ampliada:</strong> Un texto más largo con formato HTML mostrado en la página de ubicación."

msgid "<strong>Utvidet beskrivelse:</strong> En lengre tekst med rik tekstformatering (HTML) som vises på taksonomisiden. Her kan du beskrive kategorien, stedet eller instruktøren med tekst, bilder og annen informasjon."
msgstr "<strong>Descripción ampliada:</strong> Un texto más largo con formato de texto enriquecido (HTML) mostrado en la página de taxonomía. Aquí puede describir la categoría, ubicación o instructor con texto, imágenes y otra información."

msgid "<strong>Velge eksisterende side:</strong> Du kan også velge en eksisterende WordPress-side fra dropdown-menyen og tilordne den til en funksjon. Lim inn kortkoden manuelt. Koden kan du kopiere fra ikonet <i class=\"ka-icon icon-code-simple-solid-full\" style=\"height: 14px;\"></i> ved siden av navnet."
msgstr "<strong>Seleccionar página existente:</strong> También puede seleccionar una página de WordPress existente del menú desplegable y asignarla a una función. Pegue el shortcode manualmente. Puede copiar el código del icono <i class=\"ka-icon icon-code-simple-solid-full\" style=\"height: 14px;\"></i> junto al nombre."

msgid "<strong>Viktig:</strong> Endringer i designmal kan kreve oppdatering/refresh av cache og permalenker, spesielt ved utstrakte URL-tilpasninger."
msgstr "<strong>Importante:</strong> Los cambios en la plantilla de diseño pueden requerir actualizar la caché y los enlaces permanentes, especialmente para personalizaciones extensas de URL."

msgid "<strong>Viktig:</strong> Navnet på kursstedet i WordPress-administrasjonen er skrivebeskyttet når det kommer fra Kursagenten. For å endre navnet som vises på nettsiden, bruk navnendring-funksjonen i stedet for å redigere taksonomien direkte."
msgstr "<strong>Importante:</strong> El nombre de la ubicación de curso en el administrador de WordPress es de solo lectura cuando procede de Kursagenten. Para cambiar el nombre mostrado en el sitio web, use la función de cambio de nombre en lugar de editar la taxonomía directamente."

msgid "<strong>Viktig:</strong> Når du overskriver felter, vil de ikke lenger oppdateres automatisk fra Kursagenten. Du må manuelt oppdatere dem hvis det er endringer i Kursagenten."
msgstr "<strong>Importante:</strong> Cuando sustituye campos, ya no se actualizarán automáticamente desde Kursagenten. Debe actualizarlos manualmente si hay cambios en Kursagenten."

msgid "<strong>Vis bilder:</strong> Skru av/på bilder i listen. Best egnet om du har lastet opp bilder til kursene i Kursagenten."
msgstr "<strong>Mostrar imágenes:</strong> Active/desactive las imágenes en la lista. Más adecuado si ha subido imágenes para cursos en Kursagenten."

msgid "<strong>Vis:</strong> Kategorien vises i filteret, og kurs tagget med kategorien vises i kurslisten.<br><strong>Skjul kun kategorien fra filter:</strong> Kategorien skjules fra filteret, men kurs tagget med denne kategorien vises fortsatt i kurslisten (under sine øvrige kategorier).<br><strong>Skjul kategorien og alle tilhørende kurs:</strong> Verken kategorien eller kurs tagget med denne vises i kurslisten – nyttig for interne kategorier."
msgstr "<strong>Mostrar:</strong> La categoría aparece en el filtro y los cursos etiquetados con la categoría aparecen en la lista de cursos.<br><strong>Ocultar solo la categoría del filtro:</strong> La categoría se oculta del filtro, pero los cursos etiquetados con esta categoría siguen apareciendo en la lista de cursos (bajo sus otras categorías).<br><strong>Ocultar la categoría y todos los cursos relacionados:</strong> Ni la categoría ni los cursos etiquetados con ella aparecen en la lista de cursos – útil para categorías internas."

msgid "<strong>Visning av liste:</strong> I venstre kolonne vil listene vises som avkrysningsliste, mens over kursliten vises lister som dropdown-menyer."
msgstr "<strong>Visualización de lista:</strong> En la columna izquierda, las listas se muestran como casillas de verificación; encima de la lista de cursos, las listas se muestran como menús desplegables."

msgid "<strong>Visningstype:</strong> Velg om du vil vise hovedkurs (ett kurs per rad/boks) eller alle kursdatoer (tilsvarende \"Kursliste med filter\")."
msgstr "<strong>Tipo de visualización:</strong> Elija si mostrar cursos principales (un curso por fila/caja) o todas las fechas de curso (equivalente a «Lista de cursos con filtro»)."

msgid "<strong>Visningstype</strong> bestemmer om du vil vise hovedkurs eller alle kursdatoer."
msgstr "<strong>Tipo de visualización</strong> determina si mostrar cursos principales o todas las fechas de curso."

msgid "<strong>Visuelle detaljer:</strong> Styling, spacing og annet visuelt design."
msgstr "<strong>Detalles visuales:</strong> Estilo, espaciado y otro diseño visual."

msgid "✓ (kan overstyres i AIOSEO Pro)"
msgstr "✓ (se puede sustituir en AIOSEO Pro)"

msgid "✓ (kan overstyres i SEOPress Pro)"
msgstr "✓ (se puede sustituir en SEOPress Pro)"

