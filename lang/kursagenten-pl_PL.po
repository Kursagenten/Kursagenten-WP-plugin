msgid " - side %d av %d"
msgstr "- strona %d z %d"

msgid "-- Velg side --"
msgstr "Wybierz stronę"

msgid "– Brukes for feilsøking og oversikt"
msgstr "– Służy do rozwiązywania problemów i przeglądu"

msgid "– side %1$d av %2$d"
msgstr "– strona %1$d z %2$d"

msgid "\"Slug\" er den SEO-vennlige versjonen av url-en. Eksempel /kari-norman"
msgstr "\"Slug\" to SEO-przyjazna wersja URL. Przykład /kari-norman"

msgid "\"Slug\" er den SEO-vennlige versjonen av url-en. Eksempel /mitt-kurs"
msgstr "\"Slug\" to SEO- przyjazna wersja URL. Przykład /mój kurs"

msgid "\"Slug\" er den SEO-vennlige versjonen av url-en. Eksempel /oslo"
msgstr "„Slug” to SEO-przyjazna wersja URL. Przykład /oslo"

msgid "(100-1000px)"
msgstr "(100-1000px)"

msgid "* Merk: Denne delen er fortsatt under utvikling."
msgstr "* Uwaga: Ta sekcja jest nadal opracowywana."

msgid "%1$d %2$s valgt"
msgstr "%1$d %2$s wybrane"

msgid "%1$s har samme slug som %2$s \"%3$s\""
msgstr "%1$s ma ten sam ślimak co %2$s \"%3$s\""

msgid "%d %s valgt"
msgstr "%d %s wybrane"

msgid "← Tilbake til instruktører"
msgstr "← Powrót do instruktorów"

msgid "← Tilbake til kurskategorier"
msgstr "← Powrót do kategorii kursów"

msgid "← Tilbake til kurssteder"
msgstr "← Powrót do lokalizacji kursów"

msgid "+%d flere"
msgstr "+%d więcej"

msgid "<a href=\"admin.php?page=design\">Kursdesign</a> – Opprett ønskede sider for kurs, kategorier, steder og instruktører via \"Wordpress sider\". Kortkoder legges inn automatisk."
msgstr "<a href=\"admin.php?page=design\">Projekt kursu</a> – utwórz strony potrzebne do kursów, kategorii, lokalizacji i instruktorów za pośrednictwem „WordPress stron”. Shortcody są wstawiane automatycznie."

msgid "<em>Skjul kategorien og alle tilhørende kurs</em> – både kategorien og alle kurs som er tagget med kategorien skjules helt fra kurslisten. Nyttig for interne kategorier som ikke skal være synlige for besøkende."
msgstr "<em>Ukryj kategorię i wszystkie powiązane kursy</em> – zarówno kategoria, jak i wszystkie kursy oznaczone kategorią są całkowicie ukryte na liście kursów. Przydatne dla kategorii wewnętrznych, które nie powinny być widoczne dla odwiedzających."

msgid "<em>Skjul kun kategorien fra filter</em> – kategorien skjules fra filtervalgene, men kurs som er tagget med kategorien vises fortsatt i kurslisten under sine andre kategorier. Nyttig for «brede» tagger som ikke gir mening som filter (f.eks. «Foredrag», «HMS og sikkerhetskurs»)."
msgstr "<em>Ukryj tylko kategorię z filtra</em> – kategoria jest ukryta w opcjach filtrowania, ale kursy oznaczone kategorią nadal pojawiają się na liście kursów pod innymi kategoriami. Przydatne w przypadku tagów „szerokich”, które nie mają sensu jako filtry (np. „Wykłady”, „HMS i kursy bezpieczeństwa”)."

msgid "<em>Vis</em> – kategorien vises i filteret og kursene vises i listen (standard)."
msgstr "<em>Pokaż</em> – kategoria pojawia się w filtrze, a kursy pojawiają się na liście (domyślnie)."

msgid "<p><strong>Bruk Kursagenten instruktørprofil i stedet:</strong></p><ol><li>Slett denne instruktøren</li><li>Lagre et kurs i Kursagenten hvor instruktøren er lagt inn</li></ol>"
msgstr "<p><strong>Zamiast tego użyj profilu instruktora Kursagenten:</strong></p><ol><li>Usuń tego instruktora</li><li>Zapisz kurs w Kursagenten, do którego dodano instruktora</li></ol>"

msgid "<p><strong>Gå tilbake til Kursagenten-data:</strong></p><ol><li>Deaktiver \"Overstyr profil fra Kursagenten\" knappen</li><li>Oppdater instruktørprofilen i Kursagenten</li><li>Profilen oppdateres her. Merk: instruktøren må være knyttet til et kurs for at dataene skal bli hentet over.</li></ol><p>- Bruker du data fra Kursagenten, slipper du å holde dem oppdatert to steder.<br>- En instruktør som er opprettet i Kursagenten med det samme navnet, vil automatisk bli slått sammen med denne instruktøren.</p>"
msgstr "<p><strong>Wróć do danych Kursagenten:</strong></p><ol><li>Wyłącz przycisk „Zastąp profil z Kursagenten”</li><li> Zaktualizuj profil instruktora w Kursagenten</li><li>Profil został zaktualizowany tutaj. Uwaga: instruktor musi być połączony z kursem, aby dane mogły zostać pobrane.</li></ol><p>- Jeśli korzystasz z danych z Kursagenten, nie musisz ich aktualizować w dwóch miejscach.<br>- Instruktor utworzony w Kursagenten z ta sama nazwa zostanie automatycznie połączona z tym instruktorem.</p>"

msgid "<strong>Advarsel:</strong> Navn og slug på kurssteder kan ikke endres her. Du kan endre navnet under <a href=\"%s\">Synkronisering</a>."
msgstr "<strong>Ostrzeżenie:</strong> Tutaj nie można zmienić nazwy i sluga dla lokalizacji kursów. Nazwę można zmienić w sekcji <a href=\"%s\">Synchronizacja</a>."

msgid "<strong>Alternativt bilde:</strong> Et ekstra bilde som kan brukes på instruktørsiden."
msgstr "<strong>Alternatywny obraz:</strong> dodatkowy obraz, który można wykorzystać na stronie instruktora."

msgid "<strong>Antall per side:</strong> Velg antall kurs som skal vises per side."
msgstr "<strong>Liczba na stronie:</strong> Wybierz, ile kursów ma być wyświetlanych na stronie."

msgid "<strong>Automatisk opprettelse:</strong> Gå til <a href=\"admin.php?page=design#section-systemsider\">Kursdesign → Wordpress sider</a> og klikk på \"Opprett side\" for hver side du trenger. Kortkoden legges inn automatisk."
msgstr "<strong>Automatyczne tworzenie:</strong> Przejdź do <a href=\"admin.php?page=design#section-systemsider\">strony projektowania kursu → WordPress</a> i kliknij „Utwórz stronę” dla każdej potrzebnej strony. Krótki kod jest wstawiany automatycznie."

msgid "<strong>Automatisk opprydding:</strong> Det kjøres også en automatisk nattlig opprydding klokken 03:00 hver natt, så det er ikke alltid nødvendig å kjøre opprydding manuelt. Bruk manuell opprydding hvis du har mange utløpte kursdatoer som vises på nettsiden og ønsker å rydde opp umiddelbart."
msgstr "<strong>Automatyczne czyszczenie:</strong> Automatyczne czyszczenie nocne odbywa się również o godzinie 03:00 każdego wieczoru, więc czyszczenie ręczne nie zawsze jest konieczne. Skorzystaj z ręcznego czyszczenia, jeśli masz wiele wygasłych dat kursów wyświetlanych na stronie internetowej i chcesz je natychmiast wyczyścić."

msgid "<strong>Automatisk synkronisering via webhooks:</strong> Når webhooks er konfigurert, oppdateres kursene automatisk når de endres i Kursagenten. Dette er den anbefalte metoden for løpende oppdateringer."
msgstr "<strong>Automatyczna synchronizacja za pomocą webhooków:</strong> po skonfigurowaniu webhooków kursy są aktualizowane automatycznie po ich zmianie w Kursagenten. Jest to zalecana metoda dokonywania bieżących aktualizacji."

msgid "<strong>Automatisk:</strong> Steder blir automatisk tilordnet til regioner basert på fylke når regioner er aktivert."
msgstr "<strong>Automatycznie:</strong> Lokalizacje są automatycznie przypisywane do regionów na podstawie powiatu, gdy regiony są włączone."

msgid "<strong>Avkrysning før synkronisering:</strong> Når du klikker på \"Hent alle kurs fra Kursagenten\", kan du kryss av for \"Rydd opp i kurs etter synkronisering\". Dette kjører opprydding automatisk etter at synkroniseringen er fullført. <strong>NB:</strong> Opprydding tar 3-5 minutter ekstra."
msgstr "<strong>Pole wyboru przed synchronizacją:</strong> Po kliknięciu „Pobierz wszystkie kursy z Kursagenten” możesz zaznaczyć „Wyczyść kursy po synchronizacji”. Spowoduje to automatyczne czyszczenie po zakończeniu synchronizacji. <strong>Uwaga:</strong> sprzątanie zajmuje dodatkowe 3–5 minut."

msgid "<strong>Bilde:</strong> Et bilde som vises på stedssiden og i lister."
msgstr "<strong>Image: Obraz</strong> wyświetlany na stronie lokalizacji i na listach."

msgid "<strong>Bilde:</strong> Last opp et hovedbilde som vises på taksonomisiden og i lister."
msgstr "<strong>Obraz:</strong> Prześlij główny obraz wyświetlany na stronie taksonomii i na listach."

msgid "<strong>Bilder:</strong> Bruk plassholder-bilder via kortkodene om du mangler bilder."
msgstr "<strong>Obrazy:</strong> użyj obrazów zastępczych za pomocą skrótów, jeśli brakuje obrazów."

msgid "<strong>Bredde:</strong> Velg om du vil bruke temaets standardbredde eller full bredde. Stort sett vil standardbredde fungerer som tiltenkt."
msgstr "<strong>Szerokość:</strong> Wybierz, czy chcesz użyć domyślnej szerokości motywu, czy pełnej szerokości. W większości przypadków szerokość domyślna działa zgodnie z przeznaczeniem."

msgid "<strong>Bruk i kortkoder:</strong> Du kan filtrere kurssteder basert på region i kortkoden <code class=\"copytext\">[kurssteder]</code>:"
msgstr "<strong>Użyj w shortcodach:</strong> Możesz filtrować lokalizacje kursów według regionu w <code class=\"copytext\">[kurssteder]</code> shortcode:"

msgid "<strong>Bygg ditt eget design</strong> er aktivt. Du kan fortsatt styre kursdata-visning under."
msgstr "<strong>Build your own design</strong> is active. You can still control course data display below."

msgid "<strong>Bygg ditt eget design</strong> er aktivt. Kursagenten bruker WordPress sitt malhierarki, slik at tema/page builder kan styre oppsett."
msgstr "<strong>Build your own design</strong> is active. Kursagenten uses the WordPress template hierarchy so your theme/page builder can control the layout."

msgid "<strong>Byggeblokker kommer:</strong> vi planlegger moduler for blant annet kursliste med kurssteder/lenker og informasjon om kommende kurs."
msgstr "<strong>Blocks coming soon:</strong> we are planning modules for course lists with course locations/links and information about upcoming courses."

msgid "<strong>Cache:</strong> Tøm cache hvis du ikke ser endringer umiddelbart."
msgstr "<strong>Cache:</strong> Clear cache if you do not see changes immediately."

msgid "<strong>Designendringer:</strong> Hvis designendringer ikke vises, kan det være nødvendig å tømme cache og oppdatere permalenker."
msgstr "<strong>Design changes:</strong> If design changes do not appear, you may need to clear cache and update permalinks."

msgid "<strong>E-post:</strong> Instruktørens e-postadresse."
msgstr "<strong>Email:</strong> The instructor's email address."

msgid "<strong>Egen opprydding:</strong> Du kan også kjøre opprydding separat ved å klikke på knappen \"Rydd opp i kurs\" på <a href=\"admin.php?page=kursinnstillinger\">Synkronisering</a>-siden. Dette er nyttig hvis du bare ønsker å rydde opp uten å synkronisere alle kursene på nytt."
msgstr "<strong>Separate cleanup:</strong> You can also run cleanup separately by clicking the \"Clean up courses\" button on the <a href=\"admin.php?page=kursinnstillinger\">Synchronization</a> page. This is useful if you only want to clean up without re-synchronizing all courses."

msgid "<strong>Eget innhold over/under:</strong> Du kan legge inn vanlig innhold i editoren over og under kortkoden for å skrive en introduksjon, legge til bilder eller annen informasjon."
msgstr "<strong>Custom content above/below:</strong> You can add regular content in the editor above and below the shortcode to write an introduction, add images or other information."

msgid "<strong>Ekstra felter:</strong> Spesifikke felter avhengig av taksonomitypen (se nedenfor)."
msgstr "<strong>Extra fields:</strong> Specific fields depending on the taxonomy type (see below)."

msgid "<strong>Enkel - kun tittel og kort beskrivelse:</strong> Tittel og kort beskrivelse, deretter kursliste. Egnet når du ikke har bilder eller utvidet beskrivelse."
msgstr "<strong>Simple – title and short description only:</strong> Title and short description, then course list. Suitable when you do not have images or extended description."

msgid "<strong>Enkle kort:</strong> Hvite kort med overskrift og tekst. Viser neste tilgjengelige dato for kursene. Mulig å velge antall kolonner for desktop, tablet og mobil."
msgstr "<strong>Simple cards:</strong> White cards with heading and text. Shows the next available date for courses. You can choose the number of columns for desktop, tablet and mobile."

msgid "<strong>Felles designmal:</strong> Alle taksonomier bruker samme designmal."
msgstr "<strong>Shared design template:</strong> All taxonomies use the same design template."

msgid "<strong>Grid:</strong> Et rutenett med kurskort i flere kolonner. Mulig å velge antall kolonner for desktop, tablet og mobil."
msgstr "<strong>Grid:</strong> A grid of course cards in multiple columns. You can choose the number of columns for desktop, tablet and mobile."

msgid "<strong>Hovedbilde:</strong> Et bilde som vises på kategorisiden og i lister."
msgstr "<strong>Main image:</strong> An image displayed on the category page and in lists."

msgid "<strong>Hva er kortkoder?</strong> Kortkoder er små koder du plasserer i innhold (sider/innlegg) for å vise dynamiske lister og komponenter fra pluginen."
msgstr "<strong>What are shortcodes?</strong> Shortcodes are small codes you place in content (pages/posts) to display dynamic lists and components from the plugin."

msgid "<strong>Hvor brukes de?</strong> Vanligvis på egne sider eller innlegg (f.eks. «Kurs», «Kurskategorier», «Kurssteder», «Instruktører»). Du kan også bruke dem i menyen eller widgets."
msgstr "<strong>Where are they used?</strong> Usually on dedicated pages or posts (e.g. \"Courses\", \"Course categories\", \"Course locations\", \"Instructors\"). You can also use them in menus or widgets."

msgid "<strong>Ikon:</strong> Et alternativt bilde som kan brukes i stedet for hovedbilde i lister. Her er det fint å laste opp png-ikoner (bruk <code>kilde=ikon</code> i kortkoden)."
msgstr "<strong>Icon:</strong> An alternative image that can be used instead of the main image in lists. PNG icons work well here (use <code>kilde=ikon</code> in the shortcode)."

msgid "<strong>Instruktører</strong> – Inneholder <code class=\"copytext\">[instruktorer]</code> for å vise alle instruktører."
msgstr "<strong>Instructors</strong> – Contains <code class=\"copytext\">[instruktorer]</code> to display all instructors."

msgid "<strong>Kompakt:</strong> En mer kompakt listevisning med mindre mellomrom. Uten bakgrunn, og med færre kurselementer"
msgstr "<strong>Compact:</strong> A more compact list view with less spacing. No background, and fewer course elements."

msgid "<strong>Kort beskrivelse:</strong> En kort tekst som kan vises i lister og oversikter. Vises ofte direkte under overskriften."
msgstr "<strong>Short description:</strong> A short text that can be displayed in lists and overviews. Often shown directly below the heading."

msgid "<strong>Kort beskrivelse:</strong> En kort tekst som kan vises i lister."
msgstr "<strong>Short description:</strong> A short text that can be displayed in lists."

msgid "<strong>Kort beskrivelse:</strong> En kort tekst som kan vises i lister. Vises ofte direkte under overskriften."
msgstr "<strong>Short description:</strong> A short text that can be displayed in lists. Often shown directly below the heading."

msgid "<strong>Kurs</strong> – Inneholder <code class=\"copytext\">[kursliste]</code> for å vise alle kurs med filtre."
msgstr "<strong>Courses</strong> – Contains <code class=\"copytext\">[kursliste]</code> to display all courses with filters."

msgid "<strong>Kurskategorier</strong> – Inneholder <code class=\"copytext\">[kurskategorier]</code> for å vise alle kategorier."
msgstr "<strong>Course categories</strong> – Contains <code class=\"copytext\">[kurskategorier]</code> to display all categories."

msgid "<strong>Kursliste (kun for kurskategorier):</strong> Tre alternativer styrer hvordan kategorien påvirker kurslisten:"
msgstr "<strong>Course list (course categories only):</strong> Three options control how the category affects the course list:"

msgid "<strong>Kursliste med filter </strong><span class=\"smal\"><span class=\"copytext\">[kursliste]</span></span><br><span class=\"copytext small\">[kursliste kategori=\"web\" sted=\"oslo\" måned=\"9\" språk=\"norsk\" list_type=\"grid\" filter=\"topp\" knapper=\"signup_link\" bilder=\"yes\" vis=\"-sluttdato\" st=sted/st=ikke-sted klasse=\"min-klasse\"]</span>"
msgstr "<strong>Course list with filter </strong><span class=\"smal\"><span class=\"copytext\">[kursliste]</span></span><br><span class=\"copytext small\">[kursliste kategori=\"web\" sted=\"oslo\" måned=\"9\" språk=\"norsk\" list_type=\"grid\" filter=\"topp\" knapper=\"signup_link\" bilder=\"yes\" vis=\"-sluttdato\" st=sted/st=ikke-sted klasse=\"min-klasse\"]</span>"

msgid "<strong>Kurssteder opprettes automatisk</strong> når du synkroniserer kurs fra Kursagenten. Du kan ikke legge til kurssteder manuelt her."
msgstr "<strong>Course locations are created automatically</strong> when you synchronize courses from Kursagenten. You cannot add course locations manually here."

msgid "<strong>Kurssteder</strong> – Inneholder <code class=\"copytext\">[kurssteder]</code> for å vise alle kurssteder."
msgstr "<strong>Course locations</strong> – Contains <code class=\"copytext\">[kurssteder]</code> to display all course locations."

msgid "<strong>Layout og struktur:</strong> Hvor elementene plasseres på siden (header, innhold, sidekolonne, footer)."
msgstr "<strong>Layout and structure:</strong> Where elements are placed on the page (header, content, sidebar, footer)."

msgid "<strong>Layout:</strong> Velg designet på siden. Dette styrer hvor/hvordan tittel, tekst, hovedbilde og kursliste vises."
msgstr "<strong>Layout:</strong> Choose the page design. This controls where/how title, text, main image and course list are displayed."

msgid "<strong>Layout</strong> bestemmer oppsettet av elementer på siden (header, kolonner, hooks).</br><strong>Listedesign</strong> bestemmer hvordan kursene vises i listen (standard, rutenett, ren, kompakt, dato og tittel). </br><strong>Visningstype</strong> bestemmer om du vil vise hovedkurs eller alle kursdatoer."
msgstr "<strong>Layout</strong> determines the arrangement of elements on the page (header, columns, hooks).</br><strong>List design</strong> determines how courses are displayed in the list (default, grid, plain, compact, date and title). </br><strong>Display type</strong> determines whether to show main courses or all course dates."

msgid "<strong>Liste med instruktører </strong><span class=\"smal\"><span class=\"copytext\">[instruktorer]</span></span><br><span class=\"copytext small\" style=\"color:#666\">[instruktorer layout=\"stablet/rad/liste\" grid=3 gridtablet=2 gridmobil=1 radavstand=\"1rem\" stil=\"standard/kort\" bildestr=\"100px\" bildeform=\"avrundet/rund/firkantet/10px\" bildeformat=\"4/3\" overskrift=\"h3\" fontmin=\"13px\" fontmaks=\"15px\" avstand=\"2em .5em\" skygge=\"ja\" skjul=\"Iris,Anna\" utdrag=\"ja\" beskrivelse=\"ja\" klasse=\"min-klasse\"]</span>"
msgstr "<strong>Instructor list </strong><span class=\"smal\"><span class=\"copytext\">[instruktorer]</span></span><br><span class=\"copytext small\" style=\"color:#666\">[instruktorer layout=\"stablet/rad/liste\" grid=3 gridtablet=2 gridmobil=1 radavstand=\"1rem\" stil=\"standard/kort\" bildestr=\"100px\" bildeform=\"avrundet/rund/firkantet/10px\" bildeformat=\"4/3\" overskrift=\"h3\" fontmin=\"13px\" fontmaks=\"15px\" avstand=\"2em .5em\" skygge=\"ja\" skjul=\"Iris,Anna\" utdrag=\"ja\" beskrivelse=\"ja\" klasse=\"min-klasse\"]</span>"

msgid "<strong>Liste med kurskategorier </strong><span class=\"smal\"><span class=\"copytext\">[kurskategorier]</span></span><br><span class=\"copytext small\" style=\"color:#666\">[kurskategorier kilde=\"bilde/ikon\" layout=\"stablet/rad/liste\" grid=3 gridtablet=2 gridmobil=1  radavstand=\"1rem\" stil=\"standard/kort\" bildestr=\"100px\" bildeform=\"avrundet/rund/firkantet/10px\" bildeformat=\"4/3\" overskrift=\"h3\" fontmin=\"13\" fontmaks=\"18\" avstand=\"2em .5em\" skygge=\"ja\" vis=\"hovedkategorier/subkategorier/slug/standard\" st=sted/st=ikke-sted utdrag=\"ja\" klasse=\"min-klasse\"]</span>"
msgstr "<strong>Course category list </strong><span class=\"smal\"><span class=\"copytext\">[kurskategorier]</span></span><br><span class=\"copytext small\" style=\"color:#666\">[kurskategorier kilde=\"bilde/ikon\" layout=\"stablet/rad/liste\" grid=3 gridtablet=2 gridmobil=1  radavstand=\"1rem\" stil=\"standard/kort\" bildestr=\"100px\" bildeform=\"avrundet/rund/firkantet/10px\" bildeformat=\"4/3\" overskrift=\"h3\" fontmin=\"13\" fontmaks=\"18\" avstand=\"2em .5em\" skygge=\"ja\" vis=\"hovedkategorier/subkategorier/slug/standard\" st=sted/st=ikke-sted utdrag=\"ja\" klasse=\"min-klasse\"]</span>"

msgid "<strong>Liste med kurssteder </strong><span class=\"smal\"><span class=\"copytext\">[kurssteder]</span></span><br><span class=\"copytext small\" style=\"color:#666\">[kurssteder layout=\"stablet/rad/liste\" grid=3 gridtablet=2 gridmobil=1 radavstand=\"1rem\" stil=\"standard/kort\" bildestr=\"100px\" bildeform=\"avrundet/rund/firkantet/10px\" bildeformat=\"4/3\" overskrift=\"h3\" fontmin=\"13px\" fontmaks=\"15px\" avstand=\"2em .5em\" skygge=\"ja\" utdrag=\"ja\" vis=\"standard/alta,oslo,bergen\" region=\"østlandet\" stedinfo=\"ja\" klasse=\"min-klasse\"]</span>"
msgstr "<strong>Course location list </strong><span class=\"smal\"><span class=\"copytext\">[kurssteder]</span></span><br><span class=\"copytext small\" style=\"color:#666\">[kurssteder layout=\"stablet/rad/liste\" grid=3 gridtablet=2 gridmobil=1 radavstand=\"1rem\" stil=\"standard/kort\" bildestr=\"100px\" bildeform=\"avrundet/rund/firkantet/10px\" bildeformat=\"4/3\" overskrift=\"h3\" fontmin=\"13px\" fontmaks=\"15px\" avstand=\"2em .5em\" skygge=\"ja\" utdrag=\"ja\" vis=\"standard/alta,oslo,bergen\" region=\"østlandet\" stedinfo=\"ja\" klasse=\"min-klasse\"]</span>"

msgid "<strong>Listedesign:</strong> Velg designet på kurslisten (standard, rutenett, kompakt, enkle kort...)"
msgstr "<strong>List design:</strong> Choose the course list design (default, grid, compact, simple cards...)"

msgid "<strong>Listedesign:</strong> Velg listedesign (standard, rutenett, kompakt, enkel liste, enkle kort)."
msgstr "<strong>List design:</strong> Choose list design (default, grid, compact, simple list, simple cards)."

msgid "<strong>Listedesign</strong> bestemmer hvordan kursene vises i listen (standard, rutenett, ren, kompakt, dato og tittel)."
msgstr "<strong>List design</strong> determines how courses are displayed in the list (default, grid, plain, compact, date and title)."

msgid "<strong>Manuell synkronisering:</strong> Gå til <a href=\"admin.php?page=kursinnstillinger\">Synkronisering</a> og klikk på \"Hent alle kurs fra Kursagenten\". Dette bør gjøres første gang du setter opp pluginen, og ved behov for å oppdatere alle kursene samtidig."
msgstr "<strong>Manual synchronization:</strong> Go to <a href=\"admin.php?page=kursinnstillinger\">Synchronization</a> and click \"Fetch all courses from Kursagenten\". This should be done the first time you set up the plugin, and when you need to update all courses at once."

msgid "<strong>Manuelt:</strong> Du kan endre region for individuelle steder ved å redigere kursstedet i <a href=\"edit-tags.php?taxonomy=ka_course_location&post_type=ka_course\">Kurssteder</a>-oversikten."
msgstr "<strong>Manual:</strong> You can change the region for individual locations by editing the course location in the <a href=\"edit-tags.php?taxonomy=ka_course_location&post_type=ka_course\">Course locations</a> overview."

msgid "<strong>Merk:</strong> Regioner må være aktivert for at filtreringen skal fungere. Du kan også endre region for individuelle kurssteder ved å redigere kursstedet i <a href=\"edit-tags.php?taxonomy=ka_course_location&post_type=ka_course\">Kurssteder</a>-oversikten."
msgstr "<strong>Note:</strong> Regions must be enabled for filtering to work. You can also change the region for individual course locations by editing the location in the <a href=\"edit-tags.php?taxonomy=ka_course_location&post_type=ka_course\">Course locations</a> overview."

msgid "<strong>Navn:</strong> Instruktørens navn (kan deles opp i fornavn og etternavn)."
msgstr "<strong>Name:</strong> The instructor's name (can be split into first and last name)."

msgid "<strong>Navn:</strong> Kategorinavnet (kommer fra Kursagenten, bør ikke endres)."
msgstr "<strong>Name:</strong> The category name (comes from Kursagenten, should not be changed)."

msgid "<strong>Navn:</strong> Stedsnavnet (kommer fra Kursagenten, men kan endres via navnendring-funksjonen)."
msgstr "<strong>Name:</strong> The location name (comes from Kursagenten, but can be changed via the name change feature)."

msgid "<strong>Navnendring på kurssteder:</strong><br>Du kan endre navn på kurssteder under <a href=\"%s\">Synkronisering → Navnendring på kurssteder</a>. Når du endrer navn på et sted, blir også slugs (nettadressen) på kursene som har dette stedet oppdatert.<br> Det gamle stedet blir ikke slettet, men blir ikke lenger synlig på nettsiden."
msgstr "<strong>Name change for course locations:</strong><br>You can change course location names under <a href=\"%s\">Synchronization → Course location name changes</a>. When you change a location name, slugs (URLs) for courses with this location are also updated.<br> The old location is not deleted, but is no longer visible on the website."

msgid "<strong>Når bør du bruke kortkoder?</strong> Hvis du bygger sidene med Elementor eller andre page builders, vil kortkoder sannsynligvis være det du må bruke."
msgstr "<strong>When should you use shortcodes?</strong> If you build pages with Elementor or other page builders, shortcodes will likely be what you need to use."

msgid "<strong>Obs:</strong> For at brukerne skal kunne slå filteret av og på, må du dra <em>«Ledige kurs»</em> inn i «Filtre i venstre kolonne» eller «Filtre over kurslisten» under Filterinnstillinger."
msgstr "<strong>Note:</strong> For users to be able to turn the filter on and off, you must drag <em>\"Available courses\"</em> into \"Filters in left column\" or \"Filters above course list\" under Filter settings."

msgid "<strong>OBS!</strong> Fyll inn <a href=\"#kursagenten-innstillinger\" style=\"color:white; text-decoration: underline;\">innstillinger fra Kursagenten</a> før du henter alle kursene dine (synkroniser alle kurs)."
msgstr "<strong>NOTE!</strong> Enter <a href=\"#kursagenten-innstillinger\" style=\"color:white; text-decoration: underline;\">settings from Kursagenten</a> before fetching all your courses (sync all courses)."

msgid "<strong>Overstyr profil fra Kursagenten:</strong> Aktiver denne for å kunne redigere navn, e-post og telefon. Når aktivert, vil ikke disse feltene oppdateres automatisk fra Kursagenten ved synkronisering."
msgstr "<strong>Override profile from Kursagenten:</strong> Enable this to edit name, email and phone. When enabled, these fields will not be updated automatically from Kursagenten during synchronization."

msgid "<strong>Overstyr profilbilde:</strong> Aktiver denne for å bruke et eget opplastet bilde i stedet for bildet fra Kursagenten."
msgstr "<strong>Override profile image:</strong> Enable this to use your own uploaded image instead of the image from Kursagenten."

msgid "<strong>Page builder (Kadence Elements, Elementor m.fl.):</strong> Hvis du vil styre single/archive/taksonomi med page builder-betingelser, gå til <a href=\"admin.php?page=design#section-enkeltkurs\">Kursdesign → Enkeltkurs</a> og aktiver <em>Bruk WordPress sitt standard malhierarki</em>. Da lar pluginen tema/page builder velge mal uten å tvinge pluginens egne layout-filer."
msgstr "<strong>Page builder (Kadence Elements, Elementor, etc.):</strong> If you want to control single/archive/taxonomy with page builder conditions, go to <a href=\"admin.php?page=design#section-enkeltkurs\">Course design → Single course</a> and enable <em>Use WordPress default template hierarchy</em>. The plugin then lets the theme/page builder choose the template without forcing the plugin's own layout files."

msgid "<strong>Permalenker:</strong> Ved endring av URL-innstillinger, lagre «Permalenker» på nytt."
msgstr "<strong>Permalinks:</strong> When changing URL settings, save \"Permalinks\" again."

msgid "<strong>Plassering:</strong> Filtrene velges ved å dra dem til korrekt plassering. Du kan velge å vise dem til venstre for kurslisten og/eller over kurslisten."
msgstr "<strong>Placement:</strong> Choose filters by dragging them to the correct position. You can show them to the left of the course list and/or above the course list."

msgid "<strong>Profil - rundt bilde og tittel:</strong> Rundt bilde, deretter tittel og beskrivelse, deretter kursliste"
msgstr "<strong>Profile – around image and title:</strong> Around the image, then title and description, then course list."

msgid "<strong>Profilbilde:</strong> Et hovedbilde som vises på instruktørsiden og i lister. Dette kan være fra Kursagenten eller et eget opplastet bilde."
msgstr "<strong>Profile image:</strong> A main image displayed on the instructor page and in lists. This can be from Kursagenten or your own uploaded image."

msgid "<strong>Region:</strong> (Hvis regioner er aktivert) Velg hvilken region stedet tilhører."
msgstr "<strong>Region:</strong> (If regions are enabled) Choose which region the location belongs to."

msgid "<strong>Regioner:</strong><br>Du kan aktivere og administrere regioner under <a href=\"%s\">Synkronisering → Regioner</a>."
msgstr "<strong>Regions:</strong><br>You can enable and manage regions under <a href=\"%s\">Synchronization → Regions</a>."

msgid "<strong>Regioner:</strong><br>Regioner er aktivert. Du kan administrere regioninndelingen under <a href=\"%s\">Synkronisering → Regioner</a>. Tilhørighet til en region kan endres under hvert kurssted."
msgstr "<strong>Regions:</strong><br>Regions are enabled. You can manage regional division under <a href=\"%s\">Synchronization → Regions</a>. Regional assignment can be changed for each course location."

msgid "<strong>Rekkefølge på elementer:</strong> Hvilken rekkefølge informasjonen vises i (introtekst, hovedinnhold, kursdatoer, instruktører, osv.)."
msgstr "<strong>Element order:</strong> The order in which information is displayed (intro text, main content, course dates, instructors, etc.)."

msgid "<strong>Rekkefølge:</strong> Du kan også dra i filtrene for å endre rekkefølgen de vises i."
msgstr "<strong>Order:</strong> You can also drag filters to change the order they are displayed in."

msgid "<strong>Ren og enkel liste:</strong> Basert på Standard liste, men uten bakgrunn, og med færre kurselementer"
msgstr "<strong>Clean and simple list:</strong> Based on Standard list, but without background and with fewer course elements."

msgid "<strong>Separate designmaler:</strong> Aktiver dette for å kunne velge forskjellige designmaler for kategorier, steder og instruktører."
msgstr "<strong>Separate design templates:</strong> Enable this to choose different design templates for categories, locations and instructors."

msgid "<strong>Skjul i automenyer:</strong> Når aktivert, skjules kategorien i autogenererte menyer som bruker kortkoden <code>[ka-meny]</code>. Dette er nyttig hvis du har kategorier som ikke skal vises i hovedmenyen."
msgstr "<strong>Hide in auto menus:</strong> When enabled, the category is hidden in auto-generated menus that use the <code>[ka-meny]</code> shortcode. Useful if you have categories that should not appear in the main menu."

msgid "<strong>Skjul i oversiktslister:</strong> Når aktivert, skjules kategorien i kortkoder som <code>[kurskategorier]</code> og lignende lister. Kategorien vil fortsatt være tilgjengelig direkte via URL."
msgstr "<strong>Hide in overview lists:</strong> When enabled, the category is hidden in shortcodes such as <code>[kurskategorier]</code> and similar lists. The category will still be accessible directly via URL."

msgid "<strong>Slug:</strong> URL-vennlig versjon av navnet (bør ikke endres da det kan føre til ødelagte lenker)."
msgstr "<strong>Slug:</strong> URL-friendly version of the name (should not be changed as it may break links)."

msgid "<strong>Slug:</strong> URL-vennlig versjon av navnet (oppdateres automatisk ved navnendring)."
msgstr "<strong>Slug:</strong> URL-friendly version of the name (updated automatically when the name changes)."

msgid "<strong>Standard - med bilde og beskrivelse:</strong> Tittel og beskrivelse, deretter bilde og beskrivelse, deretter kursliste"
msgstr "<strong>Default – with image and description:</strong> Title and description, then image and description, then course list."

msgid "<strong>Standard:</strong> 1 kolonne"
msgstr "<strong>Default:</strong> 1 column"

msgid "<strong>Standard:</strong> 100px"
msgstr "<strong>Default:</strong> 100px"

msgid "<strong>Standard:</strong> 1rem"
msgstr "<strong>Default:</strong> 1rem"

msgid "<strong>Standard:</strong> 2 kolonner"
msgstr "<strong>Default:</strong> 2 columns"

msgid "<strong>Standard:</strong> 2em .5em"
msgstr "<strong>Default:</strong> 2em .5em"

msgid "<strong>Standard:</strong> 3 kolonner"
msgstr "<strong>Default:</strong> 3 columns"

msgid "<strong>Standard:</strong> En tradisjonell listevisning med kurskort, ett kurs per rad/boks."
msgstr "<strong>Default:</strong> A traditional list view with course cards, one course per row/box."

msgid "<strong>Synkronisering:</strong> Hvis kurs ikke oppdateres automatisk, sjekk at webhooks er konfigurert korrekt i Kursagenten."
msgstr "<strong>Synchronization:</strong> If courses are not updated automatically, check that webhooks are configured correctly in Kursagenten."

msgid "<strong>Tagger eller lister:</strong> Filtrene kan velges som tagger eller avkrysningsliste. Tagger er knapper som velger ett filter av gangen, og avkrysningsliste er en liste som kan velge flere filter samtidig."
msgstr "<strong>Tags or lists:</strong> Filters can be shown as tags or checkboxes. Tags are buttons that select one filter at a time; checkboxes allow selecting multiple filters at once."

msgid "<strong>Telefon:</strong> Instruktørens telefonnummer."
msgstr "<strong>Phone:</strong> The instructor's phone number."

msgid "<strong>Test:</strong> Besøk frontend og se at det ser ut som det skal."
msgstr "<strong>Test:</strong> Visit the frontend and verify it looks as expected."

msgid "<strong>Utvidet beskrivelse:</strong> En lengre tekst med HTML-formatering som vises på instruktørsiden."
msgstr "<strong>Extended description:</strong> A longer text with HTML formatting displayed on the instructor page."

msgid "<strong>Utvidet beskrivelse:</strong> En lengre tekst med HTML-formatering som vises på kategorisiden."
msgstr "<strong>Extended description:</strong> A longer text with HTML formatting displayed on the category page."

msgid "<strong>Utvidet beskrivelse:</strong> En lengre tekst med HTML-formatering som vises på stedssiden."
msgstr "<strong>Extended description:</strong> A longer text with HTML formatting displayed on the location page."

msgid "<strong>Utvidet beskrivelse:</strong> En lengre tekst med rik tekstformatering (HTML) som vises på taksonomisiden. Her kan du beskrive kategorien, stedet eller instruktøren med tekst, bilder og annen informasjon."
msgstr "<strong>Extended description:</strong> A longer text with rich text formatting (HTML) displayed on the taxonomy page. Here you can describe the category, location or instructor with text, images and other information."

msgid "<strong>Velge eksisterende side:</strong> Du kan også velge en eksisterende WordPress-side fra dropdown-menyen og tilordne den til en funksjon. Lim inn kortkoden manuelt. Koden kan du kopiere fra ikonet <i class=\"ka-icon icon-code-simple-solid-full\" style=\"height: 14px;\"></i> ved siden av navnet."
msgstr "<strong>Select existing page:</strong> You can also select an existing WordPress page from the dropdown and assign it to a function. Paste the shortcode manually. You can copy the code from the <i class=\"ka-icon icon-code-simple-solid-full\" style=\"height: 14px;\"></i> icon next to the name."

msgid "<strong>Viktig:</strong> Endringer i designmal kan kreve oppdatering/refresh av cache og permalenker, spesielt ved utstrakte URL-tilpasninger."
msgstr "<strong>Important:</strong> Changes to the design template may require cache refresh and permalink updates, especially for extensive URL customizations."

msgid "<strong>Viktig:</strong> Navnet på kursstedet i WordPress-administrasjonen er skrivebeskyttet når det kommer fra Kursagenten. For å endre navnet som vises på nettsiden, bruk navnendring-funksjonen i stedet for å redigere taksonomien direkte."
msgstr "<strong>Important:</strong> The course location name in WordPress admin is read-only when it comes from Kursagenten. To change the name shown on the website, use the name change feature instead of editing the taxonomy directly."

msgid "<strong>Viktig:</strong> Når du overskriver felter, vil de ikke lenger oppdateres automatisk fra Kursagenten. Du må manuelt oppdatere dem hvis det er endringer i Kursagenten."
msgstr "<strong>Important:</strong> When you override fields, they will no longer be updated automatically from Kursagenten. You must update them manually if there are changes in Kursagenten."

msgid "<strong>Vis bilder:</strong> Skru av/på bilder i listen. Best egnet om du har lastet opp bilder til kursene i Kursagenten."
msgstr "<strong>Show images:</strong> Turn images in the list on/off. Best suited if you have uploaded images for courses in Kursagenten."

msgid "<strong>Vis:</strong> Kategorien vises i filteret, og kurs tagget med kategorien vises i kurslisten.<br><strong>Skjul kun kategorien fra filter:</strong> Kategorien skjules fra filteret, men kurs tagget med denne kategorien vises fortsatt i kurslisten (under sine øvrige kategorier).<br><strong>Skjul kategorien og alle tilhørende kurs:</strong> Verken kategorien eller kurs tagget med denne vises i kurslisten – nyttig for interne kategorier."
msgstr "<strong>Show:</strong> The category appears in the filter, and courses tagged with the category appear in the course list.<br><strong>Hide only the category from filter:</strong> The category is hidden from the filter, but courses tagged with this category still appear in the course list (under their other categories).<br><strong>Hide the category and all related courses:</strong> Neither the category nor courses tagged with it appear in the course list – useful for internal categories."

msgid "<strong>Visning av liste:</strong> I venstre kolonne vil listene vises som avkrysningsliste, mens over kursliten vises lister som dropdown-menyer."
msgstr "<strong>List display:</strong> In the left column, lists are shown as checkboxes; above the course list, lists are shown as dropdown menus."

msgid "<strong>Visningstype:</strong> Velg om du vil vise hovedkurs (ett kurs per rad/boks) eller alle kursdatoer (tilsvarende \"Kursliste med filter\")."
msgstr "<strong>Display type:</strong> Choose whether to show main courses (one course per row/box) or all course dates (equivalent to \"Course list with filter\")."

msgid "<strong>Visningstype</strong> bestemmer om du vil vise hovedkurs eller alle kursdatoer."
msgstr "<strong>Display type</strong> determines whether to show main courses or all course dates."

msgid "<strong>Visuelle detaljer:</strong> Styling, spacing og annet visuelt design."
msgstr "<strong>Visual details:</strong> Styling, spacing and other visual design."

