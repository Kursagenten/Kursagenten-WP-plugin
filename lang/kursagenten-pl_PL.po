msgstr "Lub"

msgid "En feil oppstod under filtreringen."
msgstr "Wystąpił błąd podczas filtrowania."

msgid "En feil oppstod under henting av filter counts"
msgstr "Wystąpił błąd podczas pobierania liczników filtrów"

msgid "En ukjent feil oppstod under filtreringen."
msgstr "Podczas filtrowania wystąpił nieznany błąd."

msgid "Endre navn på nytt sted"
msgstr "Zmień nazwę nowej lokalizacji"

msgid "Endre navnet på instruktøren"
msgstr "Zmień nazwisko instruktora"

msgid "Endre url prefix"
