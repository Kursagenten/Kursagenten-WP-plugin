msgid "-- Velg side --"
msgstr "-- Seite auswählen --"

msgid "– Brukes for feilsøking og oversikt"
msgstr "– Wird für Fehlerbehebung und Übersicht verwendet"

msgid "– side %1$d av %2$d"
msgstr "– Seite %1$d von %2$d"

msgid "\"Slug\" er den SEO-vennlige versjonen av url-en. Eksempel /kari-norman"
msgstr "„Slug“ ist die SEO-freundliche Version der URL. Beispiel /kari-norman"

msgid "\"Slug\" er den SEO-vennlige versjonen av url-en. Eksempel /mitt-kurs"
msgstr "„Slug“ ist die SEO-freundliche Version der URL. Beispiel /my-course"

msgid "\"Slug\" er den SEO-vennlige versjonen av url-en. Eksempel /oslo"
msgstr "„Slug“ ist die SEO-freundliche Version der URL. Beispiel /oslo"

msgid "(100-1000px)"
msgstr "(100-1000px)"

msgid "* Merk: Denne delen er fortsatt under utvikling."
msgstr "* Hinweis: Dieser Abschnitt befindet sich noch in der Entwicklung."

msgid "%1$d %2$s valgt"
msgstr "%1$d %2$s ausgewählt"

msgid "%1$s har samme slug som %2$s \"%3$s\""
msgstr "%1$s hat denselben Slug wie %2$s „%3$s“"

msgid "%d %s valgt"
msgstr "%d %s ausgewählt"

msgid "← Tilbake til instruktører"
msgstr "← Zurück zu Dozenten"

msgid "← Tilbake til kurskategorier"
msgstr "← Zurück zu Kurskategorien"

msgid "← Tilbake til kurssteder"
msgstr "← Zurück zu Kursorten"

msgid "+%d flere"
msgstr "+%d mehr"

msgid "<a href=\"admin.php?page=design\">Kursdesign</a> – Opprett ønskede sider for kurs, kategorier, steder og instruktører via \"Wordpress sider\". Kortkoder legges inn automatisk."
msgstr "<a href=\"admin.php?Seite=Design\">KursDesign</a> – Erstellen the Seiten you need for Kurse, Kategorien, Standorte and Dozenten via \"WordPress-Seiten\". Shortcodes are inserted automatischally."

msgid "<em>Skjul kategorien og alle tilhørende kurs</em> – både kategorien og alle kurs som er tagget med kategorien skjules helt fra kurslisten. Nyttig for interne kategorier som ikke skal være synlige for besøkende."
msgstr "<em>Ausblenden the Kategorie and all related Kurse</em> – both the Kategorie and all Kurse tagged with the Kategorie are completely hidden from the Kurs list. Useful for internal Kategorien that should not be visible to visitors."

msgid "<em>Skjul kun kategorien fra filter</em> – kategorien skjules fra filtervalgene, men kurs som er tagget med kategorien vises fortsatt i kurslisten under sine andre kategorier. Nyttig for «brede» tagger som ikke gir mening som filter (f.eks. «Foredrag», «HMS og sikkerhetskurs»)."
msgstr "<em>Ausblenden only the Kategorie from filter</em> – the Kategorie is hidden from filtern options, but Kurse tagged with the Kategorie still appear in the Kurs list under their other Kategorien. Useful for \"broad\" tags that do not make sense as Filter (e.g. \"Lectures\", \"HMS and safety Kurse\")."

msgid "<em>Vis</em> – kategorien vises i filteret og kursene vises i listen (standard)."
msgstr "<em>Show</em> – the Kategorie appears in the filtern and Kurse appear in the list (Standard)."

msgid "<p><strong>Bruk Kursagenten instruktørprofil i stedet:</strong></p><ol><li>Slett denne instruktøren</li><li>Lagre et kurs i Kursagenten hvor instruktøren er lagt inn</li></ol>"
msgstr "<p><strong>Verwenden Sie the Kursagenten Dozent profile instead:</strong></p><ol><li>Löschen this Dozent</li><li>Speichern a Kurs in Kursagenten where the Dozent is added</li></ol>"

msgid "<p><strong>Gå tilbake til Kursagenten-data:</strong></p><ol><li>Deaktiver \"Overstyr profil fra Kursagenten\" knappen</li><li>Oppdater instruktørprofilen i Kursagenten</li><li>Profilen oppdateres her. Merk: instruktøren må være knyttet til et kurs for at dataene skal bli hentet over.</li></ol><p>- Bruker du data fra Kursagenten, slipper du å holde dem oppdatert to steder.<br>- En instruktør som er opprettet i Kursagenten med det samme navnet, vil automatisk bli slått sammen med denne instruktøren.</p>"
msgstr "<p><strong>Return to Kursagenten data:</strong></p><ol><li>Deaktivieren Sie the \"Profil von Kursagenten überschreiben\" button</li><li>Aktualisieren the Dozent profile in Kursagenten</li><li>The profile is updated here. Hinweis: the Dozent must be linked to a Kurs for the data to be fetched.</li></ol><p>- If you verwenden Sie data from Kursagenten, Sie haben nicht need to keep it updated in two places.<br>- An Dozent created in Kursagenten with the same name will automatischally be merged with this Dozent.</p>"

msgid "<strong>Advarsel:</strong> Navn og slug på kurssteder kan ikke endres her. Du kan endre navnet under <a href=\"%s\">Synkronisering</a>."
msgstr "<strong>Warnung:</strong> Name and slug for Kurs Standorte cannot be changed here. Sie können change the name under <a href=\"%s\">Synchronisation</a>."

msgid "<strong>Alternativt bilde:</strong> Et ekstra bilde som kan brukes på instruktørsiden."
msgstr "<strong>Alternatives Bild:</strong> An extra Bild that can be used on the Dozent Seite."

msgid "<strong>Antall per side:</strong> Velg antall kurs som skal vises per side."
msgstr "<strong>Number per Seite:</strong> Wählen Sie how many Kurse to display per Seite."

msgid "<strong>Automatisk opprettelse:</strong> Gå til <a href=\"admin.php?page=design#section-systemsider\">Kursdesign → Wordpress sider</a> og klikk på \"Opprett side\" for hver side du trenger. Kortkoden legges inn automatisk."
msgstr "<strong>Automatisch creation:</strong> Gehen Sie zu <a href=\"admin.php?Seite=Design#section-systemsider\">KursDesign → WordPress-Seiten</a> and klicken Sie \"Erstellen Seite\" for each Seite you need. The shortcode is inserted automatischally."

msgid "<strong>Automatisk opprydding:</strong> Det kjøres også en automatisk nattlig opprydding klokken 03:00 hver natt, så det er ikke alltid nødvendig å kjøre opprydding manuelt. Bruk manuell opprydding hvis du har mange utløpte kursdatoer som vises på nettsiden og ønsker å rydde opp umiddelbart."
msgstr "<strong>Automatisch cleanup:</strong> An automatisch nightly cleanup also runs at 03:00 every night, so manuell cleanup is not always necessary. Verwenden Sie manuell cleanup if Sie haben many expired Kurs dates showing on the website and want to clean up immediately."

msgid "<strong>Automatisk synkronisering via webhooks:</strong> Når webhooks er konfigurert, oppdateres kursene automatisk når de endres i Kursagenten. Dette er den anbefalte metoden for løpende oppdateringer."
msgstr "<strong>Automatisch Synchronisation via webhooks:</strong> When webhooks are configured, Kurse are updated automatischally when they change in Kursagenten. This is the empfohlen method for ongoing updates."

msgid "<strong>Automatisk:</strong> Steder blir automatisk tilordnet til regioner basert på fylke når regioner er aktivert."
msgstr "<strong>Automatisch:</strong> Standorte are automatischally assigned to regions based on county when regions are enabled."

msgid "<strong>Avkrysning før synkronisering:</strong> Når du klikker på \"Hent alle kurs fra Kursagenten\", kan du kryss av for \"Rydd opp i kurs etter synkronisering\". Dette kjører opprydding automatisk etter at synkroniseringen er fullført. <strong>NB:</strong> Opprydding tar 3-5 minutter ekstra."
msgstr "<strong>Checkbox before Synchronisation:</strong> Wenn Sie klicken Sie \"Fetch all Kurse from Kursagenten\", Sie können aktivieren Sie \"Kurse nach der Synchronisation bereinigen\". This runs cleanup automatischally after Synchronisation is complete. <strong>Hinweis:</strong> Cleanup takes an extra 3–5 minutes."

msgid "<strong>Bilde:</strong> Et bilde som vises på stedssiden og i lister."
msgstr "<strong>Bild:</strong> An Bild displayed on the Standort Seite and in lists."

msgid "<strong>Bilde:</strong> Last opp et hovedbilde som vises på taksonomisiden og i lister."
msgstr "<strong>Bild:</strong> Upload a main Bild displayed on the taxonomy Seite and in lists."

msgid "<strong>Bilder:</strong> Bruk plassholder-bilder via kortkodene om du mangler bilder."
msgstr "<strong>Bilder:</strong> Verwenden Sie placeholder Bilder via shortcodes if you are missing Bilder."

msgid "<strong>Bredde:</strong> Velg om du vil bruke temaets standardbredde eller full bredde. Stort sett vil standardbredde fungerer som tiltenkt."
msgstr "<strong>Width:</strong> Wählen Sie whether to verwenden Sie the theme's Standard width or full width. In most cases, Standard width works as intended."

msgid "<strong>Bruk i kortkoder:</strong> Du kan filtrere kurssteder basert på region i kortkoden <code class=\"copytext\">[kurssteder]</code>:"
msgstr "<strong>Verwenden Sie in shortcodes:</strong> Sie können filtern Kurs Standorte by region in the <code class=\"copytext\">[kurssteder]</code> shortcode:"

msgid "<strong>Bygg ditt eget design</strong> er aktivt. Du kan fortsatt styre kursdata-visning under."
msgstr "<strong>Build your own Design</strong> is active. Sie können still control Kurs data display below."

msgid "<strong>Bygg ditt eget design</strong> er aktivt. Kursagenten bruker WordPress sitt malhierarki, slik at tema/page builder kan styre oppsett."
msgstr "<strong>Build your own Design</strong> is active. Kursagenten uses the WordPress template hierarchy so your theme/Seite builder can control the layout."

msgid "<strong>Byggeblokker kommer:</strong> vi planlegger moduler for blant annet kursliste med kurssteder/lenker og informasjon om kommende kurs."
msgstr "<strong>Blocks coming soon:</strong> we are planning modules for Kurs lists with Kurs Standorte/links and information about upcoming Kurse."

msgid "<strong>Cache:</strong> Tøm cache hvis du ikke ser endringer umiddelbart."
msgstr "<strong>Cache:</strong> Clear cache if Sie haben nicht see changes immediately."

msgid "<strong>Designendringer:</strong> Hvis designendringer ikke vises, kan det være nødvendig å tømme cache og oppdatere permalenker."
msgstr "<strong>Design changes:</strong> If Design changes do not appear, you may need to clear cache and aktualisieren permalinks."

msgid "<strong>E-post:</strong> Instruktørens e-postadresse."
msgstr "<strong>Email:</strong> The Dozent's email address."

msgid "<strong>Egen opprydding:</strong> Du kan også kjøre opprydding separat ved å klikke på knappen \"Rydd opp i kurs\" på <a href=\"admin.php?page=kursinnstillinger\">Synkronisering</a>-siden. Dette er nyttig hvis du bare ønsker å rydde opp uten å synkronisere alle kursene på nytt."
msgstr "<strong>Separate cleanup:</strong> Sie können also run cleanup separately by clicking the \"Kurse bereinigen\" button on the <a href=\"admin.php?Seite=kursinnstillinger\">Synchronisation</a> Seite. This is useful if you only want to clean up without re-synchronizing all Kurse."

msgid "<strong>Eget innhold over/under:</strong> Du kan legge inn vanlig innhold i editoren over og under kortkoden for å skrive en introduksjon, legge til bilder eller annen informasjon."
msgstr "<strong>Benutzerdefiniert content above/below:</strong> Sie können hinzufügen regular content in the editor above and below the shortcode to write an introduction, hinzufügen Bilder or other information."

msgid "<strong>Ekstra felter:</strong> Spesifikke felter avhengig av taksonomitypen (se nedenfor)."
msgstr "<strong>Felder adicionales:</strong> Felder específicos según el tipo de Taxonomie (véase abajo)."

msgid "<strong>Enkel - kun tittel og kort beskrivelse:</strong> Tittel og kort beskrivelse, deretter kursliste. Egnet når du ikke har bilder eller utvidet beskrivelse."
msgstr "<strong>Simple – title and short Beschreibung only:</strong> Title and short Beschreibung, then Kurs list. Suitable when Sie haben nicht have Bilder or extended Beschreibung."

msgid "<strong>Enkle kort:</strong> Hvite kort med overskrift og tekst. Viser neste tilgjengelige dato for kursene. Mulig å velge antall kolonner for desktop, tablet og mobil."
msgstr "<strong>Simple cards:</strong> White cards with heading and text. Shows the next verfügbar date for Kurse. Sie können wählen Sie the number of columns for desktop, tablet and mobile."

msgid "<strong>Felles designmal:</strong> Alle taksonomier bruker samme designmal."
msgstr "<strong>Shared Design template:</strong> All taxonomies verwenden Sie the same Design template."

msgid "<strong>Grid:</strong> Et rutenett med kurskort i flere kolonner. Mulig å velge antall kolonner for desktop, tablet og mobil."
msgstr "<strong>Grid:</strong> A grid of Kurs cards in multiple columns. Sie können wählen Sie the number of columns for desktop, tablet and mobile."

msgid "<strong>Hovedbilde:</strong> Et bilde som vises på kategorisiden og i lister."
msgstr "<strong>Hauptbild:</strong> An Bild displayed on the Kategorie Seite and in lists."

msgid "<strong>Hva er kortkoder?</strong> Kortkoder er små koder du plasserer i innhold (sider/innlegg) for å vise dynamiske lister og komponenter fra pluginen."
msgstr "<strong>What are shortcodes?</strong> Shortcodes are small codes you place in content (Seiten/posts) to display dynamic lists and components from the plugin."

msgid "<strong>Hvor brukes de?</strong> Vanligvis på egne sider eller innlegg (f.eks. «Kurs», «Kurskategorier», «Kurssteder», «Instruktører»). Du kan også bruke dem i menyen eller widgets."
msgstr "<strong>Where are they used?</strong> Usually on dedicated Seiten or posts (e.g. \"Kurse\", \"Kurskategorien\", \"Kursorte\", \"Dozenten\"). Sie können also verwenden Sie them in menus or widgets."

msgid "<strong>Ikon:</strong> Et alternativt bilde som kan brukes i stedet for hovedbilde i lister. Her er det fint å laste opp png-ikoner (bruk <code>kilde=ikon</code> i kortkoden)."
msgstr "<strong>Icon:</strong> An alternative Bild that can be used instead of the main Bild in lists. PNG icons work well here (verwenden Sie <code>kilde=ikon</code> in the shortcode)."

msgid "<strong>Instruktører</strong> – Inneholder <code class=\"copytext\">[instruktorer]</code> for å vise alle instruktører."
msgstr "<strong>Dozenten</strong> – Contains <code class=\"copytext\">[instruktorer]</code> to display all Dozenten."

msgid "<strong>Kompakt:</strong> En mer kompakt listevisning med mindre mellomrom. Uten bakgrunn, og med færre kurselementer"
msgstr "<strong>Compact:</strong> A more compact list view with less spacing. No background, and fewer Kurs elements."

msgid "<strong>Kort beskrivelse:</strong> En kort tekst som kan vises i lister og oversikter. Vises ofte direkte under overskriften."
msgstr "<strong>Kurzbeschreibung:</strong> A short text that can be displayed in lists and Übersichts. Often shown directly below the heading."

msgid "<strong>Kort beskrivelse:</strong> En kort tekst som kan vises i lister."
msgstr "<strong>Kurzbeschreibung:</strong> A short text that can be displayed in lists."

msgid "<strong>Kort beskrivelse:</strong> En kort tekst som kan vises i lister. Vises ofte direkte under overskriften."
msgstr "<strong>Kurzbeschreibung:</strong> Ein kurzer Text, der in Listen angezeigt werden kann. Wird oft direkt unter der Überschrift angezeigt."

msgid "<strong>Kurs</strong> – Inneholder <code class=\"copytext\">[kursliste]</code> for å vise alle kurs med filtre."
msgstr "<strong>Kurse</strong> – Contains <code class=\"copytext\">[kursliste]</code> to display all Kurse with Filter."

msgid "<strong>Kurskategorier</strong> – Inneholder <code class=\"copytext\">[kurskategorier]</code> for å vise alle kategorier."
msgstr "<strong>Kurskategorien</strong> – Contains <code class=\"copytext\">[kurskategorier]</code> to display all Kategorien."

msgid "<strong>Kursliste (kun for kurskategorier):</strong> Tre alternativer styrer hvordan kategorien påvirker kurslisten:"
msgstr "<strong>Kursliste (Kurs Kategorien only):</strong> Three options control how the Kategorie affects the Kurs list:"

msgid "<strong>Kursliste med filter </strong><span class=\"smal\"><span class=\"copytext\">[kursliste]</span></span><br><span class=\"copytext small\">[kursliste kategori=\"web\" sted=\"oslo\" måned=\"9\" språk=\"norsk\" list_type=\"grid\" filter=\"topp\" knapper=\"signup_link\" bilder=\"yes\" vis=\"-sluttdato\" st=sted/st=ikke-sted klasse=\"min-klasse\"]</span>"
msgstr "<strong>Kursliste with filtern </strong><span class=\"smal\"><span class=\"copytext\">[kursliste]</span></span><br><span class=\"copytext small\">[kursliste kategori=\"web\" sted=\"oslo\" måned=\"9\" språk=\"norsk\" list_type=\"grid\" filter=\"topp\" knapper=\"signup_link\" bilder=\"yes\" vis=\"-sluttdato\" st=sted/st=ikke-sted klasse=\"min-klasse\"]</span>"

msgid "<strong>Kurssteder opprettes automatisk</strong> når du synkroniserer kurs fra Kursagenten. Du kan ikke legge til kurssteder manuelt her."
msgstr "<strong>Kursorte are created automatischally</strong> wenn Sie synchronize Kurse from Kursagenten. You cannot hinzufügen Kurs Standorte manuellly here."

msgid "<strong>Kurssteder</strong> – Inneholder <code class=\"copytext\">[kurssteder]</code> for å vise alle kurssteder."
msgstr "<strong>Kursorte</strong> – Contains <code class=\"copytext\">[kurssteder]</code> to display all Kurs Standorte."

msgid "<strong>Layout og struktur:</strong> Hvor elementene plasseres på siden (header, innhold, sidekolonne, footer)."
msgstr "<strong>Layout and structure:</strong> Where elements are placed on the Seite (header, content, sidebar, footer)."

msgid "<strong>Layout:</strong> Velg designet på siden. Dette styrer hvor/hvordan tittel, tekst, hovedbilde og kursliste vises."
msgstr "<strong>Layout:</strong> Wählen Sie the Seite Design. This controls where/how title, text, main Bild and Kurs list are displayed."

msgid "<strong>Layout</strong> bestemmer oppsettet av elementer på siden (header, kolonner, hooks).</br><strong>Listedesign</strong> bestemmer hvordan kursene vises i listen (standard, rutenett, ren, kompakt, dato og tittel). </br><strong>Visningstype</strong> bestemmer om du vil vise hovedkurs eller alle kursdatoer."
msgstr "<strong>Layout</strong> determines the arrangement of elements on the Seite (header, columns, hooks).</br><strong>List Design</strong> determines how Kurse are displayed in the list (Standard, grid, plain, compact, date and title). </br><strong>Display type</strong> determines whether to anzeigen main Kurse or all Kurs dates."

msgid "<strong>Liste med instruktører </strong><span class=\"smal\"><span class=\"copytext\">[instruktorer]</span></span><br><span class=\"copytext small\" style=\"color:#666\">[instruktorer layout=\"stablet/rad/liste\" grid=3 gridtablet=2 gridmobil=1 radavstand=\"1rem\" stil=\"standard/kort\" bildestr=\"100px\" bildeform=\"avrundet/rund/firkantet/10px\" bildeformat=\"4/3\" overskrift=\"h3\" fontmin=\"13px\" fontmaks=\"15px\" avstand=\"2em .5em\" skygge=\"ja\" skjul=\"Iris,Anna\" utdrag=\"ja\" beskrivelse=\"ja\" klasse=\"min-klasse\"]</span>"
msgstr "<strong>Dozent list </strong><span class=\"smal\"><span class=\"copytext\">[instruktorer]</span></span><br><span class=\"copytext small\" style=\"color:#666\">[instruktorer layout=\"stablet/rad/liste\" grid=3 gridtablet=2 gridmobil=1 radavstand=\"1rem\" stil=\"Standard/kort\" bildestr=\"100px\" bildeform=\"avrundet/rund/firkantet/10px\" bildeformat=\"4/3\" overskrift=\"h3\" fontmin=\"13px\" fontmaks=\"15px\" avstand=\"2em .5em\" skygge=\"ja\" skjul=\"Iris,Anna\" utdrag=\"ja\" beskrivelse=\"ja\" klasse=\"min-klasse\"]</span>"

msgid "<strong>Liste med kurskategorier </strong><span class=\"smal\"><span class=\"copytext\">[kurskategorier]</span></span><br><span class=\"copytext small\" style=\"color:#666\">[kurskategorier kilde=\"bilde/ikon\" layout=\"stablet/rad/liste\" grid=3 gridtablet=2 gridmobil=1  radavstand=\"1rem\" stil=\"standard/kort\" bildestr=\"100px\" bildeform=\"avrundet/rund/firkantet/10px\" bildeformat=\"4/3\" overskrift=\"h3\" fontmin=\"13\" fontmaks=\"18\" avstand=\"2em .5em\" skygge=\"ja\" vis=\"hovedkategorier/subkategorier/slug/standard\" st=sted/st=ikke-sted utdrag=\"ja\" klasse=\"min-klasse\"]</span>"
msgstr "<strong>Kurskategorie list </strong><span class=\"smal\"><span class=\"copytext\">[kurskategorier]</span></span><br><span class=\"copytext small\" style=\"color:#666\">[kurskategorier kilde=\"bilde/ikon\" layout=\"stablet/rad/liste\" grid=3 gridtablet=2 gridmobil=1  radavstand=\"1rem\" stil=\"Standard/kort\" bildestr=\"100px\" bildeform=\"avrundet/rund/firkantet/10px\" bildeformat=\"4/3\" overskrift=\"h3\" fontmin=\"13\" fontmaks=\"18\" avstand=\"2em .5em\" skygge=\"ja\" vis=\"hovedkategorier/subkategorier/slug/Standard\" st=sted/st=ikke-sted utdrag=\"ja\" klasse=\"min-klasse\"]</span>"

msgid "<strong>Liste med kurssteder </strong><span class=\"smal\"><span class=\"copytext\">[kurssteder]</span></span><br><span class=\"copytext small\" style=\"color:#666\">[kurssteder layout=\"stablet/rad/liste\" grid=3 gridtablet=2 gridmobil=1 radavstand=\"1rem\" stil=\"standard/kort\" bildestr=\"100px\" bildeform=\"avrundet/rund/firkantet/10px\" bildeformat=\"4/3\" overskrift=\"h3\" fontmin=\"13px\" fontmaks=\"15px\" avstand=\"2em .5em\" skygge=\"ja\" utdrag=\"ja\" vis=\"standard/alta,oslo,bergen\" region=\"østlandet\" stedinfo=\"ja\" klasse=\"min-klasse\"]</span>"
msgstr "<strong>Kursort list </strong><span class=\"smal\"><span class=\"copytext\">[kurssteder]</span></span><br><span class=\"copytext small\" style=\"color:#666\">[kurssteder layout=\"stablet/rad/liste\" grid=3 gridtablet=2 gridmobil=1 radavstand=\"1rem\" stil=\"Standard/kort\" bildestr=\"100px\" bildeform=\"avrundet/rund/firkantet/10px\" bildeformat=\"4/3\" overskrift=\"h3\" fontmin=\"13px\" fontmaks=\"15px\" avstand=\"2em .5em\" skygge=\"ja\" utdrag=\"ja\" vis=\"Standard/alta,oslo,bergen\" region=\"østlandet\" stedinfo=\"ja\" klasse=\"min-klasse\"]</span>"

msgid "<strong>Listedesign:</strong> Velg designet på kurslisten (standard, rutenett, kompakt, enkle kort...)"
msgstr "<strong>List Design:</strong> Wählen Sie the Kurs list Design (Standard, grid, compact, simple cards...)"

msgid "<strong>Listedesign:</strong> Velg listedesign (standard, rutenett, kompakt, enkel liste, enkle kort)."
msgstr "<strong>List Design:</strong> Wählen Sie list Design (Standard, grid, compact, simple list, simple cards)."

msgid "<strong>Listedesign</strong> bestemmer hvordan kursene vises i listen (standard, rutenett, ren, kompakt, dato og tittel)."
msgstr "<strong>List Design</strong> determines how Kurse are displayed in the list (Standard, grid, plain, compact, date and title)."

msgid "<strong>Manuell synkronisering:</strong> Gå til <a href=\"admin.php?page=kursinnstillinger\">Synkronisering</a> og klikk på \"Hent alle kurs fra Kursagenten\". Dette bør gjøres første gang du setter opp pluginen, og ved behov for å oppdatere alle kursene samtidig."
msgstr "<strong>Manuell Synchronisation:</strong> Gehen Sie zu <a href=\"admin.php?Seite=kursinnstillinger\">Synchronisation</a> and klicken Sie \"Fetch all Kurse from Kursagenten\". This should be done the first time you set up the plugin, and wenn Sie need to aktualisieren all Kurse at once."

msgid "<strong>Manuelt:</strong> Du kan endre region for individuelle steder ved å redigere kursstedet i <a href=\"edit-tags.php?taxonomy=ka_course_location&post_type=ka_course\">Kurssteder</a>-oversikten."
msgstr "<strong>Manuell:</strong> Sie können change the region for individual Standorte by editing the Kurs Standort in the <a href=\"edit-tags.php?taxonomy=ka_Kurs_Standort&post_type=ka_Kurs\">Kursorte</a> Übersicht."

msgid "<strong>Merk:</strong> Regioner må være aktivert for at filtreringen skal fungere. Du kan også endre region for individuelle kurssteder ved å redigere kursstedet i <a href=\"edit-tags.php?taxonomy=ka_course_location&post_type=ka_course\">Kurssteder</a>-oversikten."
msgstr "<strong>Hinweis:</strong> Regions must be enabled for filtering to work. Sie können also change the region for individual Kurs Standorte by editing the Standort in the <a href=\"edit-tags.php?taxonomy=ka_Kurs_Standort&post_type=ka_Kurs\">Kursorte</a> Übersicht."

msgid "<strong>Navn:</strong> Instruktørens navn (kan deles opp i fornavn og etternavn)."
msgstr "<strong>Name:</strong> The Dozent's name (can be split into first and last name)."

msgid "<strong>Navn:</strong> Kategorinavnet (kommer fra Kursagenten, bør ikke endres)."
msgstr "<strong>Name:</strong> The Kategorie name (comes from Kursagenten, should not be changed)."

msgid "<strong>Navn:</strong> Stedsnavnet (kommer fra Kursagenten, men kan endres via navnendring-funksjonen)."
msgstr "<strong>Name:</strong> The Standort name (comes from Kursagenten, but can be changed via the name change feature)."

msgid "<strong>Navnendring på kurssteder:</strong><br>Du kan endre navn på kurssteder under <a href=\"%s\">Synkronisering → Navnendring på kurssteder</a>. Når du endrer navn på et sted, blir også slugs (nettadressen) på kursene som har dette stedet oppdatert.<br> Det gamle stedet blir ikke slettet, men blir ikke lenger synlig på nettsiden."
msgstr "<strong>Name change for Kurs Standorte:</strong><br>Sie können change Kurs Standort names under <a href=\"%s\">Synchronisation → Kursort name changes</a>. Wenn Sie change a Standort name, slugs (URLs) for Kurse with this Standort are also updated.<br> The old Standort is not deleted, but is no longer visible on the website."

msgid "<strong>Når bør du bruke kortkoder?</strong> Hvis du bygger sidene med Elementor eller andre page builders, vil kortkoder sannsynligvis være det du må bruke."
msgstr "<strong>When should you verwenden Sie shortcodes?</strong> If you build Seiten with Elementor or other Seite builders, shortcodes will likely be what you need to use."

msgid "<strong>Obs:</strong> For at brukerne skal kunne slå filteret av og på, må du dra <em>«Ledige kurs»</em> inn i «Filtre i venstre kolonne» eller «Filtre over kurslisten» under Filterinnstillinger."
msgstr "<strong>Hinweis:</strong> For users to be able to turn the filtern on and off, Sie müssen ziehen Sie <em>\"Verfügbare Kurse\"</em> into \"Filter in left column\" or \"Filter above Kurs list\" under Filtereinstellungen."

msgid "<strong>OBS!</strong> Fyll inn <a href=\"#kursagenten-innstillinger\" style=\"color:white; text-decoration: underline;\">innstillinger fra Kursagenten</a> før du henter alle kursene dine (synkroniser alle kurs)."
msgstr "<strong>NOTE!</strong> Geben Sie ein <a href=\"#kursagenten-innstillinger\" style=\"color:white; text-decoration: underline;\">Einstellungen from Kursagenten</a> before fetching all your Kurse (sync all Kurse)."

msgid "<strong>Overstyr profil fra Kursagenten:</strong> Aktiver denne for å kunne redigere navn, e-post og telefon. Når aktivert, vil ikke disse feltene oppdateres automatisk fra Kursagenten ved synkronisering."
msgstr "<strong>Profil von Kursagenten überschreiben:</strong> Aktivieren Sie this to bearbeiten name, email and phone. When enabled, these fields will not be updated automatischally from Kursagenten during Synchronisation."

msgid "<strong>Overstyr profilbilde:</strong> Aktiver denne for å bruke et eget opplastet bilde i stedet for bildet fra Kursagenten."
msgstr "<strong>Profilbild überschreiben:</strong> Aktivieren Sie this to verwenden Sie your own uploaded Bild instead of the Bild from Kursagenten."

msgid "<strong>Page builder (Kadence Elements, Elementor m.fl.):</strong> Hvis du vil styre single/archive/taksonomi med page builder-betingelser, gå til <a href=\"admin.php?page=design#section-enkeltkurs\">Kursdesign → Enkeltkurs</a> og aktiver <em>Bruk WordPress sitt standard malhierarki</em>. Da lar pluginen tema/page builder velge mal uten å tvinge pluginens egne layout-filer."
msgstr "<strong>Seite builder (Kadence Elements, Elementor, etc.):</strong> If you want to control single/archive/taxonomy with Seite builder conditions, gehen Sie zu <a href=\"admin.php?Seite=Design#section-enkeltkurs\">KursDesign → Einzelkurs</a> and aktivieren Sie <em>Verwenden Sie WordPress Standard template hierarchy</em>. The plugin then lets the theme/Seite builder wählen Sie the template without forcing the plugin's own layout files."

msgid "<strong>Permalenker:</strong> Ved endring av URL-innstillinger, lagre «Permalenker» på nytt."
msgstr "<strong>Permalinks:</strong> When changing URL Einstellungen, speichern \"Permalinks\" again."

msgid "<strong>Plassering:</strong> Filtrene velges ved å dra dem til korrekt plassering. Du kan velge å vise dem til venstre for kurslisten og/eller over kurslisten."
msgstr "<strong>Placement:</strong> Wählen Sie Filter by dragging them to the correct position. Sie können anzeigen them to the left of the Kurs list and/or above the Kurs list."

msgid "<strong>Profil - rundt bilde og tittel:</strong> Rundt bilde, deretter tittel og beskrivelse, deretter kursliste"
msgstr "<strong>Profile – around Bild and title:</strong> Around the Bild, then title and Beschreibung, then Kurs list."

msgid "<strong>Profilbilde:</strong> Et hovedbilde som vises på instruktørsiden og i lister. Dette kan være fra Kursagenten eller et eget opplastet bilde."
msgstr "<strong>Profilbild:</strong> A main Bild displayed on the Dozent Seite and in lists. This can be from Kursagenten or your own uploaded Bild."

msgid "<strong>Region:</strong> (Hvis regioner er aktivert) Velg hvilken region stedet tilhører."
msgstr "<strong>Region:</strong> (If regions are enabled) Wählen Sie which region the Standort belongs to."

msgid "<strong>Regioner:</strong><br>Du kan aktivere og administrere regioner under <a href=\"%s\">Synkronisering → Regioner</a>."
msgstr "<strong>Regions:</strong><br>Sie können aktivieren Sie and manage regions under <a href=\"%s\">Synchronisation → Regions</a>."

msgid "<strong>Regioner:</strong><br>Regioner er aktivert. Du kan administrere regioninndelingen under <a href=\"%s\">Synkronisering → Regioner</a>. Tilhørighet til en region kan endres under hvert kurssted."
msgstr "<strong>Regions:</strong><br>Regions are enabled. Sie können manage regional division under <a href=\"%s\">Synchronisation → Regions</a>. Regional assignment can be changed for each Kurs Standort."

msgid "<strong>Rekkefølge på elementer:</strong> Hvilken rekkefølge informasjonen vises i (introtekst, hovedinnhold, kursdatoer, instruktører, osv.)."
msgstr "<strong>Element order:</strong> The order in which information is displayed (intro text, main content, Kurs dates, Dozenten, etc.)."

msgid "<strong>Rekkefølge:</strong> Du kan også dra i filtrene for å endre rekkefølgen de vises i."
msgstr "<strong>Order:</strong> Sie können also ziehen Sie Filter to change the order they are displayed in."

msgid "<strong>Ren og enkel liste:</strong> Basert på Standard liste, men uten bakgrunn, og med færre kurselementer"
msgstr "<strong>Clean and simple list:</strong> Based on Standard list, but without background and with fewer Kurs elements."

msgid "<strong>Separate designmaler:</strong> Aktiver dette for å kunne velge forskjellige designmaler for kategorier, steder og instruktører."
msgstr "<strong>Separate Design templates:</strong> Aktivieren Sie this to wählen Sie different Design templates for Kategorien, Standorte and Dozenten."

msgid "<strong>Skjul i automenyer:</strong> Når aktivert, skjules kategorien i autogenererte menyer som bruker kortkoden <code>[ka-meny]</code>. Dette er nyttig hvis du har kategorier som ikke skal vises i hovedmenyen."
msgstr "<strong>In Automatikmenüs ausblenden:</strong> When enabled, the Kategorie is hidden in auto-generated menus that verwenden Sie the <code>[ka-meny]</code> shortcode. Useful if Sie haben Kategorien that should not appear in the main menu."

msgid "<strong>Skjul i oversiktslister:</strong> Når aktivert, skjules kategorien i kortkoder som <code>[kurskategorier]</code> og lignende lister. Kategorien vil fortsatt være tilgjengelig direkte via URL."
msgstr "<strong>In Übersichtslisten ausblenden:</strong> When enabled, the Kategorie is hidden in shortcodes such as <code>[kurskategorier]</code> and similar lists. The Kategorie will still be accessible directly via URL."

msgid "<strong>Slug:</strong> URL-vennlig versjon av navnet (bør ikke endres da det kan føre til ødelagte lenker)."
msgstr "<strong>Slug:</strong> Versión amigable für URL des Name (no Sie müssen cambiarse ya que Sie können romper Links)."

msgid "<strong>Slug:</strong> URL-vennlig versjon av navnet (oppdateres automatisk ved navnendring)."
msgstr "<strong>Slug:</strong> URL-friendly version of the name (updated automatischally when the name changes)."

msgid "<strong>Standard - med bilde og beskrivelse:</strong> Tittel og beskrivelse, deretter bilde og beskrivelse, deretter kursliste"
msgstr "<strong>Standard – with Bild and Beschreibung:</strong> Title and Beschreibung, then Bild and Beschreibung, then Kurs list."

msgid "<strong>Standard:</strong> 1 kolonne"
msgstr "<strong>Standard:</strong> 1 column"

msgid "<strong>Standard:</strong> 100px"
msgstr "<strong>Standard:</strong> 100px"

msgid "<strong>Standard:</strong> 1rem"
msgstr "<strong>Standard:</strong> 1rem"

msgid "<strong>Standard:</strong> 2 kolonner"
msgstr "<strong>Standard:</strong> 2 columns"

msgid "<strong>Standard:</strong> 2em .5em"
msgstr "<strong>Standard:</strong> 2em .5em"

msgid "<strong>Standard:</strong> 3 kolonner"
msgstr "<strong>Standard:</strong> 3 columns"

msgid "<strong>Standard:</strong> En tradisjonell listevisning med kurskort, ett kurs per rad/boks."
msgstr "<strong>Standard:</strong> A traditional list view with Kurs cards, one Kurs per row/box."

msgid "<strong>Synkronisering:</strong> Hvis kurs ikke oppdateres automatisk, sjekk at webhooks er konfigurert korrekt i Kursagenten."
msgstr "<strong>Synchronisation:</strong> If Kurse are not updated automatischally, aktivieren Sie that webhooks are configured correctly in Kursagenten."

msgid "<strong>Tagger eller lister:</strong> Filtrene kan velges som tagger eller avkrysningsliste. Tagger er knapper som velger ett filter av gangen, og avkrysningsliste er en liste som kan velge flere filter samtidig."
msgstr "<strong>Tags or lists:</strong> Filter can be shown as tags or checkboxes. Tags are buttons that wählen Sie one filtern at a time; checkboxes allow selecting multiple Filter at once."

msgid "<strong>Telefon:</strong> Instruktørens telefonnummer."
msgstr "<strong>Phone:</strong> The Dozent's phone number."

msgid "<strong>Test:</strong> Besøk frontend og se at det ser ut som det skal."
msgstr "<strong>Prueba:</strong> Besuchen Sie el frontend und prüfen Sie que se ve como se espera."

msgid "<strong>Utvidet beskrivelse:</strong> En lengre tekst med HTML-formatering som vises på instruktørsiden."
msgstr "<strong>Erweiterte Beschreibung:</strong> A longer text with HTML formatting displayed on the Dozent Seite."

msgid "<strong>Utvidet beskrivelse:</strong> En lengre tekst med HTML-formatering som vises på kategorisiden."
msgstr "<strong>Erweiterte Beschreibung:</strong> A longer text with HTML formatting displayed on the Kategorie Seite."

msgid "<strong>Utvidet beskrivelse:</strong> En lengre tekst med HTML-formatering som vises på stedssiden."
msgstr "<strong>Erweiterte Beschreibung:</strong> A longer text with HTML formatting displayed on the Standort Seite."

msgid "<strong>Utvidet beskrivelse:</strong> En lengre tekst med rik tekstformatering (HTML) som vises på taksonomisiden. Her kan du beskrive kategorien, stedet eller instruktøren med tekst, bilder og annen informasjon."
msgstr "<strong>Erweiterte Beschreibung:</strong> A longer text with rich text formatting (HTML) displayed on the taxonomy Seite. Here Sie können describe the Kategorie, Standort or Dozent with text, Bilder and other information."

msgid "<strong>Velge eksisterende side:</strong> Du kan også velge en eksisterende WordPress-side fra dropdown-menyen og tilordne den til en funksjon. Lim inn kortkoden manuelt. Koden kan du kopiere fra ikonet <i class=\"ka-icon icon-code-simple-solid-full\" style=\"height: 14px;\"></i> ved siden av navnet."
msgstr "<strong>Wählen Sie existing Seite:</strong> Sie können also wählen Sie an existing WordPress Seite from the dropdown and assign it to a function. Fügen Sie ein the shortcode manuellly. Sie können copy the code from the <i class=\"ka-icon icon-code-simple-solid-full\" style=\"height: 14px;\"></i> icon next to the name."

msgid "<strong>Viktig:</strong> Endringer i designmal kan kreve oppdatering/refresh av cache og permalenker, spesielt ved utstrakte URL-tilpasninger."
msgstr "<strong>Wichtig:</strong> Changes to the Design template may require cache refresh and permalink updates, especially for extensive URL benutzerdefiniertizations."

msgid "<strong>Viktig:</strong> Navnet på kursstedet i WordPress-administrasjonen er skrivebeskyttet når det kommer fra Kursagenten. For å endre navnet som vises på nettsiden, bruk navnendring-funksjonen i stedet for å redigere taksonomien direkte."
msgstr "<strong>Wichtig:</strong> The Kurs Standort name in WordPress admin is read-only when it comes from Kursagenten. To change the name shown on the website, verwenden Sie the name change feature instead of editing the taxonomy directly."

msgid "<strong>Viktig:</strong> Når du overskriver felter, vil de ikke lenger oppdateres automatisk fra Kursagenten. Du må manuelt oppdatere dem hvis det er endringer i Kursagenten."
msgstr "<strong>Wichtig:</strong> Wenn Sie override fields, they will no longer be updated automatischally from Kursagenten. Sie müssen aktualisieren them manuellly if there are changes in Kursagenten."

msgid "<strong>Vis bilder:</strong> Skru av/på bilder i listen. Best egnet om du har lastet opp bilder til kursene i Kursagenten."
msgstr "<strong>Anzeigen Bilder:</strong> Turn Bilder in the list on/off. Best suited if Sie haben uploaded Bilder for Kurse in Kursagenten."

msgid "<strong>Vis:</strong> Kategorien vises i filteret, og kurs tagget med kategorien vises i kurslisten.<br><strong>Skjul kun kategorien fra filter:</strong> Kategorien skjules fra filteret, men kurs tagget med denne kategorien vises fortsatt i kurslisten (under sine øvrige kategorier).<br><strong>Skjul kategorien og alle tilhørende kurs:</strong> Verken kategorien eller kurs tagget med denne vises i kurslisten – nyttig for interne kategorier."
msgstr "<strong>Show:</strong> The Kategorie appears in the filter, and Kurse tagged with the Kategorie appear in the Kurs list.<br><strong>Ausblenden only the Kategorie from filter:</strong> The Kategorie is hidden from the filter, but Kurse tagged with this Kategorie still appear in the Kurs list (under their other Kategorien).<br><strong>Ausblenden the Kategorie and all related Kurse:</strong> Neither the Kategorie nor Kurse tagged with it appear in the Kurs list – useful for internal Kategorien."

msgid "<strong>Visning av liste:</strong> I venstre kolonne vil listene vises som avkrysningsliste, mens over kursliten vises lister som dropdown-menyer."
msgstr "<strong>List display:</strong> In the left column, lists are shown as checkboxes; above the Kurs list, lists are shown as dropdown menus."

msgid "<strong>Visningstype:</strong> Velg om du vil vise hovedkurs (ett kurs per rad/boks) eller alle kursdatoer (tilsvarende \"Kursliste med filter\")."
msgstr "<strong>Display type:</strong> Wählen Sie whether to anzeigen main Kurse (one Kurs per row/box) or all Kurs dates (equivalent to \"Kursliste with filter\")."

msgid "<strong>Visningstype</strong> bestemmer om du vil vise hovedkurs eller alle kursdatoer."
msgstr "<strong>Display type</strong> determines whether to anzeigen main Kurse or all Kurs dates."

msgid "<strong>Visuelle detaljer:</strong> Styling, spacing og annet visuelt design."
msgstr "<strong>Visual details:</strong> Styling, spacing and other visual Design."

